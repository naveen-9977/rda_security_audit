@using rda_raipur.Data
@inject ApplicationDbContext _context

@{
    var carousels = _context.SiteCarousels
        .Where(c => c.IsActive && !c.IsDeleted)
        .OrderBy(c => c.DisplayOrder)
        .ToList();

    var requestCultureFeature = Context.Features.Get<Microsoft.AspNetCore.Localization.IRequestCultureFeature>();
    var currentCulture = requestCultureFeature?.RequestCulture.UICulture.Name ?? "hi";
    bool isEnglish = (currentCulture == "en");
}

<style>
    #mainCarousel {
        border-bottom: clamp(2px, 0.4vw, 4px) solid #f97316;
        box-shadow: 0 4px 20px rgba(0,0,0,0.15);
        background-color: #f8fafc;
        width: 100%;
        overflow: hidden;
        position: relative;
    }

    @@keyframes zoomEffect {
        0% {
            transform: scale(1, 1);
        }

        100% {
            transform: scale(1.15, 1.15);
        }
    }

    .carousel-item::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        height: 40%;
        background: linear-gradient(to top, rgba(15, 23, 42, 0.4) 0%, rgba(0,0,0,0) 100%);
        z-index: 1;
        pointer-events: none;
    }

    .carousel-item img {
        width: 100%;
        object-fit: cover;
        transform-origin: center center;
        transform: scale(1, 1);
        border: 0;
        vertical-align: middle;
        height: clamp(250px, 45vw, 550px);
    }

    .carousel-item.active img {
        -webkit-animation: zoomEffect 30s linear forwards;
        animation: zoomEffect 30s linear forwards;
    }

    .carousel-fade .carousel-item {
        transition: opacity 1.2s ease-in-out;
    }

    .carousel-control-prev, .carousel-control-next {
        width: clamp(10%, 8vw, 15%);
        opacity: 0;
        transition: opacity 0.4s ease;
        z-index: 10;
    }

    #mainCarousel:hover .carousel-control-prev,
    #mainCarousel:hover .carousel-control-next {
        opacity: 0.8;
    }

    .carousel-control-prev:hover, .carousel-control-next:hover {
        opacity: 1;
    }

    .carousel-control-prev-icon,
    .carousel-control-next-icon {
        background-color: #003366;
        border: 2px solid rgba(255,255,255,0.5);
        border-radius: 50%;
        padding: clamp(12px, 2vw, 20px);
        background-size: 45%;
        box-shadow: 0 4px 10px rgba(0,0,0,0.4);
        transition: all 0.3s ease;
    }

    .carousel-control-prev:hover .carousel-control-prev-icon,
    .carousel-control-next:hover .carousel-control-next-icon {
        background-color: #f97316;
        border-color: #fff;
        transform: scale(1.1);
    }

    .carousel-indicators {
        bottom: clamp(10px, 2vw, 20px);
        gap: clamp(6px, 1vw, 10px);
        z-index: 15;
    }

        .carousel-indicators [data-bs-target] {
            width: clamp(20px, 3vw, 35px);
            height: clamp(3px, 0.5vw, 5px);
            border-radius: 3px;
            background-color: #ffffff;
            border: none;
            opacity: 0.5;
            transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
        }

        .carousel-indicators .active {
            background-color: #f97316;
            width: clamp(35px, 5vw, 55px);
            opacity: 1;
            box-shadow: 0 2px 8px rgba(0,0,0,0.5);
        }

    .custom-caption {
        background: rgba(15, 23, 42, 0.65);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        padding: clamp(12px, 2vw, 18px) clamp(15px, 3vw, 30px);
        border-radius: 6px;
        border-left: clamp(4px, 0.6vw, 6px) solid #f97316;
        text-align: left;
        max-width: clamp(250px, 60%, 800px);
        bottom: clamp(12%, 15vw, 18%);
        left: clamp(5%, 8vw, 10%);
        animation: fadeSlideUp 0.8s ease-out forwards;
        z-index: 10;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }

        .custom-caption h4 {
            font-size: clamp(0.9rem, 1.5vw + 0.3rem, 1.35rem) !important;
            letter-spacing: clamp(0.2px, 0.1vw, 0.5px);
            line-height: 1.4;
        }

    @@keyframes fadeSlideUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@media (max-width: 991px) {
        .carousel-control-prev, .carousel-control-next {
            opacity: 0.5;
        }
    }
</style>

<div id="mainCarousel" class="carousel slide carousel-fade" data-bs-ride="carousel">

    @if (carousels.Count > 1)
    {
        <div class="carousel-indicators">
            @for (int i = 0; i < carousels.Count; i++)
            {
                <button type="button" data-bs-target="#mainCarousel" data-bs-slide-to="@i" class="@(i == 0 ? "active" : "")" aria-current="@(i == 0 ? "true" : "false")" aria-label="Slide @(i + 1)"></button>
            }
        </div>
    }

    <div class="carousel-inner">
        @for (int i = 0; i < carousels.Count; i++)
        {
            var item = carousels[i];
            var activeClass = i == 0 ? "active" : "";
            var captionText = currentCulture == "hi" ? item.Caption_hi : item.Caption_en;

            <div class="carousel-item @activeClass" data-bs-interval="5000">
                <img src="@item.ImagePath" class="d-block w-100" alt="@captionText">

                @if (!string.IsNullOrEmpty(captionText))
                {
                    <div class="carousel-caption d-none d-md-block custom-caption">
                        <h4 class="fw-bold text-white mb-0 text-uppercase">@captionText</h4>
                    </div>
                }
            </div>
        }
    </div>

    @if (carousels.Count > 1)
    {
        <button class="carousel-control-prev" type="button" data-bs-target="#mainCarousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Previous</span>
        </button>

        <button class="carousel-control-next" type="button" data-bs-target="#mainCarousel" data-bs-slide="next">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Next</span>
        </button>
    }
</div>