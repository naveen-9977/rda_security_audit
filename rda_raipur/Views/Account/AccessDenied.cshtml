@{
    ViewData["Title"] = "Access Denied";
    Layout = null; // Is page me hume sidebar nahi chahiye
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Access Denied - RDA Raipur</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
</head>
<body class="bg-light d-flex align-items-center justify-content-center" style="height: 100vh;">
    <div class="text-center">
        <div class="display-1 text-danger mb-3">
            <i class="bi bi-shield-lock-fill"></i>
        </div>
        <h1 class="h2 font-weight-bold text-dark mb-3">403 - Access Denied</h1>
        <p class="text-muted mb-4 lead">
            Sorry, you don't have permission to access this page.<br />
            Please contact the Administrator if you need access.
        </p>

        @if (User.IsInRole("Admin") || User.IsInRole("Employee"))
        {
            <a href="@Url.Action("Index", "AdminDashboard")" class="btn btn-primary px-4 py-2 fw-bold">
                <i class="bi bi-arrow-left me-2"></i>Go to Dashboard
            </a>
        }
        else
        {
            <a href="@Url.Action("Index", "Home")" class="btn btn-primary px-4 py-2 fw-bold">
                <i class="bi bi-arrow-left me-2"></i>Return to Home
            </a>
        }
    </div>
</body>
</html>