@model IEnumerable<rda_raipur.Models.Property.Tender_Live_Master>

@{
    ViewData["Title"] = "Master Live Tenders";
    Layout = "~/Views/AdminShared/_AdminLayout.cshtml";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="h3 mb-0 text-dark fw-semibold"><i class="bi bi-diagram-3 text-primary"></i> Master Live Tenders Dashboard</h2>
        <a asp-action="Create" class="btn btn-success shadow-sm px-4 fw-bold rounded-pill">
            <i class="bi bi-plus-circle"></i> Create New Master
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success shadow-sm"><i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]</div>
    }

    <div class="card shadow border-0 rounded-4">
        <div class="card-body">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Master ID</th>
                        <th>Scheme Name</th>
                        <th>Properties Attached</th>
                        <th>Live Dates</th>
                        <th>Status</th>
                        <th class="text-end">Manage</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold text-muted">#MST-@item.MasterId</td>
                            <td class="fw-bold text-primary fs-5"><i class="bi bi-building"></i> @item.Scheme_Name</td>
                            <td>
                                <span class="badge bg-info text-dark fs-6 px-3 py-2 rounded-pill">
                                    @item.LiveProperties.Count Units
                                </span>
                            </td>
                            <td>
                                <small class="d-block text-success fw-bold"><i class="bi bi-play-circle"></i> @item.Tender_Start_Date.ToString("dd-MMM-yyyy")</small>
                                <small class="d-block text-danger fw-bold"><i class="bi bi-stop-circle"></i> @item.Tender_End_Date.ToString("dd-MMM-yyyy")</small>
                            </td>
                            <td>
                                @if (item.Status == "Active")
                                {
                                    <span class="badge bg-success px-3 py-2">Live</span>
                                }
                                else
                                {

                                    <span class="badge bg-warning text-dark px-3 py-2">Inactive</span>
                                }
                            </td>
                            <td class="text-end">
                                <a href="@Url.Action("Manage", "TenderLive", new { masterId = item.MasterId })" class="btn btn-warning fw-bold shadow-sm rounded-pill px-4">
                                    <i class="bi bi-gear-fill"></i> Manage Master
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>