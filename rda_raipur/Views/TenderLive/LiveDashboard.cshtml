@model IEnumerable<rda_raipur.Models.Property.Tender_Live_Master>

@{
    ViewData["Title"] = "Master Live Tenders";
    Layout = "~/Views/AdminShared/_AdminLayout.cshtml";
}

<link href="~/css/master-pages.css" rel="stylesheet" />

<div class="master-container">
    <div class="master-page-header">
        <div>
            <h2 class="master-title text-capitalize">
                <i class="bi bi-diagram-3 text-primary"></i> Master Live Tenders Dashboard
            </h2>
        </div>
        <a asp-action="Create" class="btn btn-primary fw-bold px-4 shadow-sm" style="background-color: #003366; border: none;">
            <i class="bi bi-plus-circle me-1"></i> Create New Master
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm mb-4">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
        </div>
    }

    <div class="card master-card">
        <div class="card-body p-3">
            <div class="table-responsive">
                <table class="table gov-table align-middle mb-0">
                    <thead>
                        <tr>
                            <th class="ps-3" style="width: 120px;">Master ID</th>
                            <th>Scheme Name</th>
                            <th class="text-center" style="width: 160px;">Properties Attached</th>
                            <th>Live Dates</th>
                            <th class="text-center" style="width: 130px;">Status</th>
                            <th class="text-end pe-3" style="width: 180px;">Manage</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model == null || !Model.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted fw-bold">
                                    No Live Tenders found. Click "Create New Master" to begin.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-3 fw-bold text-muted">#MST-@item.MasterId</td>
                                    <td>
                                        <div class="fw-bold text-dark fs-6">
                                            <i class="bi bi-building text-secondary me-1"></i> @item.Scheme_Name
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge bg-light text-primary border border-primary-subtle px-3 py-2 rounded-pill fw-bold">
                                            <i class="bi bi-house-door me-1"></i> @(item.LiveProperties?.Count ?? 0) Units
                                        </span>
                                    </td>
                                    <td>
                                        <div class="small fw-bold text-success">
                                            <i class="bi bi-play-circle me-1"></i> @item.Tender_Start_Date.ToString("dd-MMM-yyyy")
                                        </div>
                                        <div class="small fw-bold text-danger mt-1">
                                            <i class="bi bi-stop-circle me-1"></i> @item.Tender_End_Date.ToString("dd-MMM-yyyy")
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        @if (item.Status == "Active")
                                        {
                                            <span class="gov-badge-active"><i class="bi bi-broadcast me-1"></i> Live</span>
                                        }
                                        else
                                        {
                                            <span class="gov-badge-inactive">Inactive</span>
                                        }
                                    </td>
                                    <td class="text-end pe-3">
                                        <a href="@Url.Action("Manage", "TenderLive", new { masterId = item.MasterId })" class="btn btn-warning btn-sm fw-bold px-3 rounded shadow-sm text-dark">
                                            <i class="bi bi-gear-fill me-1"></i> Manage Master
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}