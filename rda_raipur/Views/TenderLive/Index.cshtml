@model IEnumerable<rda_raipur.Models.Property.Tender_Live_Master>

@{
    ViewData["Title"] = "Tender Master Dashboard";
    Layout = "~/Views/AdminShared/_AdminLayout.cshtml";
}

<div class="container-fluid py-4 px-lg-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="h3 mb-1 text-dark fw-bold"><i class="bi bi- megaphone-fill text-primary me-2"></i> Live Tender Masters</h2>
            <p class="text-muted small mb-0">Overview of all active and scheduled tender groups.</p>
        </div>
        <a asp-action="Create" class="btn btn-primary shadow-sm px-4 fw-bold rounded-pill">
            <i class="bi bi-plus-circle me-1"></i> Launch New Master Tender
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm mb-4">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
        </div>
    }

    <div class="card shadow border-0 rounded-4 overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-dark text-white">
                        <tr>
                            <th class="ps-4 py-3">Master ID</th>
                            <th>Scheme Name</th>
                            <th class="text-center">Live Units</th>
                            <th>Live Window (Start - End)</th>
                            <th>Status</th>
                            <th class="text-end pe-4">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr><td colspan="6" class="text-center py-5 text-muted">No Live Tenders found. Click "Launch New Master" to begin.</td></tr>
                        }
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-muted">#MST-@item.MasterId</td>
                                <td>
                                    <div class="fw-extrabold text-dark fs-6">@item.Scheme_Name</div>
                                    <small class="text-muted">Created: @item.Created_Date.ToString("dd MMM yyyy")</small>
                                </td>
                                <td class="text-center">
                                    <span class="badge bg-primary-subtle text-primary border border-primary-subtle px-3 py-2 rounded-pill fw-bold">
                                        @item.LiveProperties.Count Properties
                                    </span>
                                </td>
                                <td>
                                    <div class="small fw-bold text-success"><i class="bi bi-calendar-check me-1"></i> @item.Tender_Start_Date.ToString("dd/MM/yy hh:mm tt")</div>
                                    <div class="small fw-bold text-danger"><i class="bi bi-calendar-x me-1"></i> @item.Tender_End_Date.ToString("dd/MM/yy hh:mm tt")</div>
                                </td>
                                <td>
                                    @if (item.Status == "Active")
                                    {
                                        <span class="badge bg-success px-3 py-2 shadow-sm"><i class="bi bi-broadcast"></i> LIVE</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary px-3 py-2 shadow-sm">INACTIVE</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <a href="@Url.Action("Manage", "TenderLive", new { masterId = item.MasterId })" class="btn btn-warning btn-sm fw-bold px-4 rounded-pill shadow-sm">
                                        <i class="bi bi-gear-fill me-1"></i> Manage & Edit
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>