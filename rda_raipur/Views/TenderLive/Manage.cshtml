@model rda_raipur.Models.Property.Tender_Live_Master

@{
    ViewData["Title"] = "Manage Master Tender";
    Layout = "~/Views/AdminShared/_AdminLayout.cshtml";
}

<style>
    .govt-section-card {
        border-radius: 12px;
        border: 1px solid #e2e8f0;
        overflow: hidden;
    }

    .govt-section-header {
        background: #f8fafc;
        border-bottom: 1px solid #e2e8f0;
        padding: 15px 20px;
    }

    .label-custom {
        font-size: 0.75rem;
        text-transform: uppercase;
        font-weight: 800;
        color: #64748b;
        margin-bottom: 4px;
    }

    .val-custom {
        font-weight: 700;
        color: #0f172a;
        margin-bottom: 15px;
    }
</style>

<div class="container-fluid py-4 px-lg-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold text-dark mb-0">Master Control: <span class="text-primary">@Model.Scheme_Name</span></h3>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a asp-action="Index">Dashboard</a></li>
                    <li class="breadcrumb-item active">Manage Master</li>
                </ol>
            </nav>
        </div>
        <a asp-action="Index" class="btn btn-outline-dark fw-bold rounded-pill shadow-sm px-4">
            <i class="bi bi-arrow-left"></i> Back to List
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success shadow-sm alert-dismissible fade show">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-4">
        <div class="col-xl-5">
            <div class="govt-section-card shadow-sm bg-white border-top border-warning border-4">
                <div class="govt-section-header">
                    <h5 class="mb-0 fw-bold text-dark"><i class="bi bi-sliders me-2"></i> Edit Master Config</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="UpdateMaster" method="post" enctype="multipart/form-data">
                        <input type="hidden" name="MasterId" value="@Model.MasterId" />
                        <input type="hidden" asp-for="Scheme_Name" />

                        <div class="row g-3">
                            <div class="col-md-12">
                                <label class="label-custom">Tender Start Date</label>
                                <input asp-for="Tender_Start_Date" type="datetime-local" class="form-control shadow-sm border-success" />
                            </div>
                            <div class="col-md-12">
                                <label class="label-custom">Tender End Date</label>
                                <input asp-for="Tender_End_Date" type="datetime-local" class="form-control shadow-sm border-danger" />
                            </div>
                            <div class="col-md-12">
                                <label class="label-custom">Tender Opening Date</label>
                                <input asp-for="Tender_Opening_Date" type="datetime-local" class="form-control shadow-sm border-warning" />
                            </div>
                            <div class="col-md-12">
                                <label class="label-custom">Visibility Status</label>
                                <select asp-for="Status" class="form-select shadow-sm">
                                    <option value="Active">Active / Live</option>
                                    <option value="Inactive">Inactive / Hidden</option>
                                </select>
                            </div>

                            <hr class="my-3 text-muted">
                            <h6 class="fw-bold small text-primary mb-2">UPDATE TENDER DOCUMENTS</h6>

                            <div class="col-md-12 mb-2">
                                <label class="label-custom">Cover Image</label>
                                <input type="file" name="TenderImage" class="form-control form-control-sm" />
                                @if (!string.IsNullOrEmpty(Model.CoverImage))
                                {
                                    <a href="@Model.CoverImage" target="_blank" class="small d-block mt-1 text-primary"><i class="bi bi-link-45deg"></i> View Current Image</a>
                                }
                            </div>
                            <div class="col-md-12 mb-2">
                                <label class="label-custom">Brochure PDF</label>
                                <input type="file" name="TenderBrochure" class="form-control form-control-sm" />
                                @if (!string.IsNullOrEmpty(Model.BrochurePdf))
                                {
                                    <a href="@Model.BrochurePdf" target="_blank" class="small d-block mt-1 text-danger"><i class="bi bi-file-earmark-pdf"></i> View Current Brochure</a>
                                }
                            </div>
                        </div>

                        <div class="mt-4 border-top pt-3 text-center">
                            <button type="submit" class="btn btn-warning w-100 fw-bold py-2 shadow-sm">
                                <i class="bi bi-check2-square me-1"></i> Update Master Settings
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-xl-7">
            <div class="govt-section-card shadow-sm bg-white border-top border-primary border-4 h-100">
                <div class="govt-section-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold text-dark"><i class="bi bi-building me-2"></i> Attached Properties (@Model.LiveProperties.Count)</h5>
                    <button type="button" class="btn btn-primary btn-sm fw-bold px-3 rounded-pill shadow-sm" data-bs-toggle="modal" data-bs-target="#addPropertyModal">
                        <i class="bi bi-plus"></i> Add Property
                    </button>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th class="ps-3">Asset Code</th>
                                    <th>House No</th>
                                    <th>Sector/Block</th>
                                    <th class="text-end pe-3">Remove</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var mapping in Model.LiveProperties)
                                {
                                    <tr>
                                        <td class="ps-3 fw-bold text-primary">@mapping.Property?.Property_Id</td>
                                        <td class="fw-bold">@mapping.Property?.House_No</td>
                                        <td>
                                            <span class="small">Sec: @mapping.Property?.sector_name_en</span><br />
                                            <span class="small">Blk: @mapping.Property?.block_name_en</span>
                                        </td>
                                        <td class="text-end pe-3">
                                            <form asp-action="RemoveProperty" method="post" onsubmit="return confirm('Remove this property from live list?');">
                                                <input type="hidden" name="mappingId" value="@mapping.MappingId" />
                                                <input type="hidden" name="masterId" value="@Model.MasterId" />
                                                <button type="submit" class="btn btn-sm text-danger border-0 bg-transparent">
                                                    <i class="bi bi-trash fs-5"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="addPropertyModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title fw-bold">Add Vacant Property</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="AddPropertyToMaster" method="post">
                <input type="hidden" name="masterId" value="@Model.MasterId" />
                <div class="modal-body p-4">
                    <label class="label-custom d-block mb-2">Select Unit from @Model.Scheme_Name</label>
                    <select name="propertyId" id="vacantPropDropdown" class="form-select shadow-sm" required>
                        <option value="">-- Loading Properties... --</option>
                    </select>
                </div>
                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary btn-sm px-4">Confirm Add</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#addPropertyModal').on('show.bs.modal', function () {
                var dropdown = $('#vacantPropDropdown');
                $.get('/TenderLive/GetVacantPropertiesForScheme', { scheme: '@Model.Scheme_Name' }, function (data) {
                    dropdown.empty().append('<option value="">-- Select Property --</option>');
                    $.each(data, function(i, item) {
                        dropdown.append('<option value="'+item.id+'">'+item.text+'</option>');
                    });
                });
            });
        });
    </script>
}