@model IEnumerable<rda_raipur.Models.TenderLiveModel>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Tender_Start_Date)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Tender_End_Date)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Property_Status)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Status)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Tender_Start_Date)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Tender_End_Date)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Property_Status)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Status)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.TenderLiveId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.TenderLiveId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.TenderLiveId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
