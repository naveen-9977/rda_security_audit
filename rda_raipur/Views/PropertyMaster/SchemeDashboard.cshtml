@model IEnumerable<rda_raipur.Models.Property.TenderPropertyCreation>

@{
    ViewData["Title"] = "Scheme Dashboard";
    Layout = "~/Views/AdminShared/_AdminLayout.cshtml";

    // Data grouping logic preserved
    var groupedSchemes = Model.GroupBy(x => string.IsNullOrEmpty(x.Scheme_name_en) ? "Unassigned" : x.Scheme_name_en)
                              .OrderBy(g => g.Key)
                              .ToList();
}

<link href="~/css/master-pages.css" rel="stylesheet" />

<style>
    .scheme-stats-card {
        background: #fff;
        border-radius: 12px;
        border: 1px solid #e2e8f0;
        transition: all 0.3s ease;
        display: block;
        text-decoration: none;
        color: inherit;
        height: 100%;
    }

        .scheme-stats-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1);
            border-color: #003366;
        }

    .stat-badge {
        font-size: 0.8rem;
        padding: 5px 10px;
        border-radius: 6px;
        font-weight: 600;
    }
</style>

<div class="master-container">
    <div class="master-page-header">
        <h3 class="master-title">
            <i class='bx bx-grid-alt text-primary'></i> Schemes Overview
        </h3>
        <a asp-action="Create" class="btn btn-primary fw-bold shadow-sm rounded-pill px-4" style="background-color: #003366; border: none;">
            <i class='bx bx-plus-circle me-1'></i> Add Property
        </a>
    </div>

    <div class="row g-4">
        @foreach (var group in groupedSchemes)
        {
            int total = group.Count();
            int vacant = group.Count(x => x.Booking_Status == "Vacant");
            int sold = total - vacant;

            <div class="col-md-6 col-xl-4">
                <a href="@Url.Action("Index", "PropertyMaster", new { scheme = group.Key })" class="scheme-stats-card shadow-sm p-0">
                    <div class="p-3 border-bottom d-flex align-items-center" style="background: #f8fafc;">
                        <div class="bg-white p-2 rounded shadow-sm me-3 border">
                            <i class='bx bx-buildings text-primary fs-4'></i>
                        </div>
                        <h4 class="mb-0 fw-bold text-dark">@group.Key</h4>
                    </div>

                    <div class="p-4">
                        <div class="d-flex justify-content-between mb-3">
                            <span class="text-muted fw-bold">Total Properties</span>
                            <span class="fw-bold fs-5">@total</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted fw-bold">Vacant</span>
                            <span class="badge bg-success-subtle text-success stat-badge">@vacant</span>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span class="text-muted fw-bold">Sold/Booked</span>
                            <span class="badge bg-danger-subtle text-danger stat-badge">@sold</span>
                        </div>
                    </div>

                    <div class="p-3 bg-light border-top text-primary fw-bold text-center rounded-bottom">
                        View Inventory <i class='bx bx-right-arrow-alt align-middle'></i>
                    </div>
                </a>
            </div>
        }
    </div>
</div>