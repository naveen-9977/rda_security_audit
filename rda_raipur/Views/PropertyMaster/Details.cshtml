@model rda_raipur.Models.Property.TenderPropertyCreation

@{
    ViewData["Title"] = "Property Details";
    Layout = "~/Views/AdminShared/_AdminLayout.cshtml";
}

<link href="~/css/master-pages.css" rel="stylesheet" />

<style>
    .detail-view-box {
        background: #f8f9fa;
        padding: 15px;
        border-radius: 8px;
        border: 1px solid #e9ecef;
        margin-bottom: 15px;
    }

    .detail-label {
        font-size: 0.75rem;
        font-weight: 700;
        color: #64748b;
        text-transform: uppercase;
        display: block;
        margin-bottom: 4px;
    }

    .detail-value {
        font-weight: 600;
        color: #0f172a;
        font-size: 0.95rem;
    }

    .price-value {
        color: #059669;
        font-weight: 800;
        font-size: 1.1rem;
    }
</style>

<div class="master-container">
    <div class="master-page-header">
        <h3 class="master-title">
            <i class='bx bx-info-circle text-primary'></i> Property Details
        </h3>
        <div>
            <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-outline-primary fw-bold rounded-pill px-4 me-2">
                <i class='bx bx-edit me-1'></i> Edit
            </a>
            <a asp-action="Index" class="btn btn-outline-secondary fw-bold rounded-pill px-4">
                <i class='bx bx-arrow-back me-1'></i> Back to List
            </a>
        </div>
    </div>

    <div class="card master-card">
        <div class="card-header bg-white border-bottom d-flex justify-content-between align-items-center p-3">
            <h5 class="mb-0 fw-bold text-dark"><i class='bx bx-buildings me-2'></i> Inventory Information</h5>
            <span class="@(Model.Booking_Status == "Vacant" ? "gov-badge-active" : "gov-badge-inactive")">
                Status: @Model.Booking_Status
            </span>
        </div>

        <div class="card-body p-4">
            <div class="premium-section-title mt-0"><i class='bx bx-map'></i> Location & Identity</div>
            <div class="row">
                <div class="col-md-3 detail-view-box">
                    <span class="detail-label">Property Code (ID)</span>
                    <div class="detail-value text-primary">@Model.Property_Id</div>
                </div>
                <div class="col-md-3 detail-view-box">
                    <span class="detail-label">Scheme Name</span>
                    <div class="detail-value">@Model.Scheme_name_en</div>
                </div>
                <div class="col-md-3 detail-view-box">
                    <span class="detail-label">Sector Name</span>
                    <div class="detail-value">@Model.sector_name_en</div>
                </div>
                <div class="col-md-3 detail-view-box">
                    <span class="detail-label">Block Name</span>
                    <div class="detail-value">@Model.block_name_en</div>
                </div>
                <div class="col-md-3 detail-view-box">
                    <span class="detail-label">House / Flat No.</span>
                    <div class="detail-value">@Model.House_No</div>
                </div>
            </div>

            <div class="premium-section-title"><i class='bx bx-layer'></i> Property Specifications</div>
            <div class="row">
                <div class="col-md-3 detail-view-box">
                    <span class="detail-label">Property Type</span>
                    <div class="detail-value">@Model.Property_Type_Name_en</div>
                </div>
                <div class="col-md-3 detail-view-box">
                    <span class="detail-label">Property Model</span>
                    <div class="detail-value">@(Model.Model_name_en ?? "N/A")</div>
                </div>
                <div class="col-md-3 detail-view-box">
                    <span class="detail-label">Flat Config</span>
                    <div class="detail-value">@(Model.Flat_name_en ?? "N/A")</div>
                </div>
                <div class="col-md-3 detail-view-box">
                    <span class="detail-label">Allotment Mode</span>
                    <div class="detail-value">@(Model.allotement_type_name_en ?? "N/A")</div>
                </div>
                <div class="col-md-3 detail-view-box">
                    <span class="detail-label">Category</span>
                    <div class="detail-value">@(Model.res_category_name_en ?? "General")</div>
                </div>
            </div>

            <div class="premium-section-title"><i class='bx bx-ruler'></i> Area Measurements</div>
            <div class="row">
                <div class="col-md-4 detail-view-box">
                    <span class="detail-label">Super Buildup Area</span>
                    <div class="detail-value">@Model.Super_Buildup_Area Sq.Ft</div>
                </div>
                <div class="col-md-4 detail-view-box">
                    <span class="detail-label">Buildup Area</span>
                    <div class="detail-value">@(Model.Buildup_Area?.ToString() ?? "N/A") Sq.Ft</div>
                </div>
                <div class="col-md-4 detail-view-box">
                    <span class="detail-label">Carpet Area</span>
                    <div class="detail-value">@(Model.Carpet_Area?.ToString() ?? "N/A") Sq.Ft</div>
                </div>
            </div>

            <div class="premium-section-title"><i class='bx bx-wallet'></i> Pricing</div>
            <div class="row">
                <div class="col-md-6 detail-view-box">
                    <span class="detail-label">Offset Price</span>
                    <div class="price-value">₹ @(Model.offset_Price != null ? Convert.ToDecimal(Model.offset_Price).ToString("N0") : "0")</div>
                </div>
                <div class="col-md-6 detail-view-box">
                    <span class="detail-label">EMD Amount</span>
                    <div class="detail-value text-danger fw-bold">₹ @(Model.EMD_Amount != null ? Convert.ToDecimal(Model.EMD_Amount).ToString("N0") : "0")</div>
                </div>
            </div>

            <div class="premium-section-title"><i class='bx bx-history'></i> System Tracking</div>
            <div class="row">
                <div class="col-md-3 detail-view-box">
                    <span class="detail-label">Created By</span>
                    <div class="detail-value text-muted">@Model.created_by</div>
                </div>
                <div class="col-md-3 detail-view-box">
                    <span class="detail-label">Created At</span>
                    <div class="detail-value text-muted">@(Model.Create_Date?.ToString("dd MMM yyyy, hh:mm tt") ?? "N/A")</div>
                </div>
                <div class="col-md-3 detail-view-box">
                    <span class="detail-label">Updated By</span>
                    <div class="detail-value text-muted">@Model.updated_by</div>
                </div>
                <div class="col-md-3 detail-view-box">
                    <span class="detail-label">Last Updated</span>
                    <div class="detail-value text-muted">@(Model.updated_Date?.ToString("dd MMM yyyy, hh:mm tt") ?? "N/A")</div>
                </div>
            </div>
        </div>
    </div>
</div>