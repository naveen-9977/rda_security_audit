@model rda_raipur.Models.Property.TenderPropertyCreation

@{
    ViewData["Title"] = "Delete Property";
    Layout = "~/Views/AdminShared/_AdminLayout.cshtml";
}

<link href="~/css/master-pages.css" rel="stylesheet" />

<div class="master-container">
    <div class="master-page-header">
        <h3 class="master-title">
            <i class='bx bx-trash text-danger'></i> Delete Property
        </h3>
        <a asp-action="Index" class="btn btn-outline-secondary fw-bold rounded-pill px-4">
            <i class='bx bx-arrow-back me-1'></i> Back to List
        </a>
    </div>

    <div class="card master-card border-danger">
        <div class="card-header bg-danger text-white p-3">
            <h5 class="mb-0 fw-bold"><i class='bx bx-error-circle me-2'></i> Are you sure you want to delete this?</h5>
        </div>
        <div class="card-body p-4">
            <p class="text-danger fw-bold">This action cannot be undone. The property will be removed from the inventory.</p>

            <div class="premium-section mt-3">
                <div class="row">
                    <div class="col-md-4">
                        <span class="text-muted fw-bold d-block">Property Code</span>
                        <div class="fw-bold fs-5">@Model.Property_Id</div>
                    </div>
                    <div class="col-md-4">
                        <span class="text-muted fw-bold d-block">Scheme</span>
                        <div class="fw-bold fs-5">@Model.Scheme_name_en</div>
                    </div>
                    <div class="col-md-4">
                        <span class="text-muted fw-bold d-block">House No.</span>
                        <div class="fw-bold fs-5">@Model.House_No</div>
                    </div>
                </div>
            </div>

            <form asp-action="Delete" method="post" class="mt-4">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger fw-bold px-5">
                    <i class='bx bx-trash me-1'></i> Confirm Delete
                </button>
                <a asp-action="Index" class="btn btn-light border fw-bold px-5 ms-2">Cancel</a>
            </form>
        </div>
    </div>
</div>