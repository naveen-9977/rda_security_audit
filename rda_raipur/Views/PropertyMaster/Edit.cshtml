@model rda_raipur.Models.Property.TenderPropertyCreation

@{
    ViewData["Title"] = "Edit Tender Property";
    Layout = "~/Views/AdminShared/_AdminLayout.cshtml";
}

<link href="~/css/master-pages.css" rel="stylesheet" />

<div class="master-container">
    <div class="master-page-header">
        <h3 class="master-title">
            <i class='bx bx-edit text-primary'></i> Edit Property Inventory
        </h3>
        <a asp-action="Index" class="btn btn-outline-secondary fw-bold rounded-pill px-4">
            <i class='bx bx-arrow-back'></i> Back to List
        </a>
    </div>

    <form asp-action="Edit" method="post" id="editForm">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="Property_Id" />
        <input type="hidden" asp-for="created_by" />
        <input type="hidden" asp-for="Create_Date" />

        <div class="premium-section">
            <div class="premium-section-title">
                <i class='bx bx-edit-alt text-primary'></i> Property Details
            </div>
            <div class="row">
                <div class="col-md-4 form-group-spaced">
                    <label class="master-label">Scheme Name</label>
                    <select asp-for="scheme_id" id="scheme_id" class="master-input form-select" asp-items="ViewBag.Schemes">
                        <option value="">-- Select Scheme --</option>
                    </select>
                </div>

                <div class="col-md-4 form-group-spaced">
                    <label class="master-label">Property Type</label>
                    <select asp-for="Property_Type_Name_en" id="Property_Type_Name_en" class="master-input form-select">
                        <option value="">-- Select Type --</option>
                        <option value="Plot">Plot</option>
                        <option value="Shop">Shop</option>
                        <option value="Flat">Flat</option>
                        <option value="House">House</option>
                    </select>
                </div>

                <div class="col-md-4 form-group-spaced">
                    <label class="master-label">Property Model (LIG/HIG/EWS)</label>
                    <select asp-for="Model_Id" id="model_id" class="master-input form-select">
                        <option value="">-- Loading Models... --</option>
                    </select>
                </div>

                <div class="col-md-4 form-group-spaced">
                    <label class="master-label">Flat Configuration</label>
                    <select asp-for="Flat_id" id="Flat_id" class="master-input form-select">
                        <option value="">-- Select Flat --</option>
                    </select>
                </div>

                <div class="col-md-4 form-group-spaced">
                    <label class="master-label">Sector Name</label>
                    <select asp-for="sector_id" id="sector_id" class="master-input form-select">
                        <option value="">-- Select Sector --</option>
                    </select>
                </div>

                <div class="col-md-4 form-group-spaced">
                    <label class="master-label">Block Name</label>
                    <select asp-for="block_id" id="block_id" class="master-input form-select">
                        <option value="">-- Select Block --</option>
                    </select>
                </div>
            </div>
        </div>

        <div class="premium-section">
            <div class="premium-section-title">
                <i class='bx bx-info-circle text-primary'></i> Financial & Identification
            </div>
            <div class="row">
                <div class="col-md-4 form-group-spaced">
                    <label class="master-label">House / Flat Number</label>
                    <input asp-for="House_No" id="House_No" class="master-input" placeholder="e.g. B-102" />
                </div>

                <div class="col-md-4 form-group-spaced">
                    <label class="master-label">Auto-Generated Property Code</label>
                    <input type="text" asp-for="Property_Id" id="Tender_Property_Id" class="master-input bg-light fw-bold text-primary" readonly />
                </div>

                <div class="col-md-4 form-group-spaced">
                    <label class="master-label">User Category (Reservation)</label>
                    <select asp-for="res_category_id" id="res_category_id" class="master-input form-select">
                        <option value="">-- Select Category --</option>
                    </select>
                </div>

                <div class="col-md-4 form-group-spaced">
                    <label class="master-label">Offset Price (₹)</label>
                    <input asp-for="offset_Price" class="master-input" type="number" step="0.01" />
                </div>

                <div class="col-md-4 form-group-spaced">
                    <label class="master-label">EMD Amount (₹)</label>
                    <input asp-for="EMD_Amount" class="master-input" type="number" step="0.01" />
                </div>

                <div class="col-md-4 form-group-spaced">
                    <label class="master-label">Super Buildup Area (Sq.Ft)</label>
                    <input asp-for="Super_Buildup_Area" class="master-input" />
                </div>

                <div class="col-md-4 form-group-spaced">
                    <label class="master-label">Buildup Area (Sq.Ft)</label>
                    <input asp-for="Buildup_Area" class="master-input" />
                </div>

                <div class="col-md-4 form-group-spaced">
                    <label class="master-label">Carpet Area (Sq.Ft)</label>
                    <input asp-for="Carpet_Area" class="master-input" />
                </div>

                <div class="col-md-4 form-group-spaced">
                    <label class="master-label">Allotment Type</label>
                    <select asp-for="allotement_type_id" asp-items="ViewBag.AllotmentList" class="master-input form-select">
                        <option value="">-- Select Allotment --</option>
                    </select>
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-end gap-3 mb-5">
            <button type="submit" class="btn btn-primary fw-bold px-5 shadow-sm" style="background-color: #003366; border: none;">
                <i class='bx bx-save me-1'></i> Update Inventory
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary fw-bold px-5">Cancel</a>
        </div>

        <div asp-validation-summary="All" class="text-danger mt-3 fw-bold"></div>
    </form>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            var currentModelId = '@Model.Model_Id';
            var currentCategoryId = '@Model.res_category_id';
            var currentFlatId = '@Model.Flat_id';
            var currentSchemeId = '@Model.scheme_id';
            var currentSectorId = '@Model.sector_id';
            var currentBlockId = '@Model.block_id';

            // Initial Data Load
            loadModels();
            loadUserCategory();
            loadFlats();

            if (currentSchemeId) {
                loadSectorsAndBlocksForEdit();
            }

            $("#scheme_id").change(function () {
                var schemeId = $(this).val();
                $("#sector_id").empty().append('<option value="">Select Sector</option>');
                $("#block_id").empty().append('<option value="">Select Block</option>');
                if(schemeId) {
                    $.get("/PropertyMaster/GetSectors", { schemeId: schemeId }, function (data) {
                        $.each(data, function (i, row) { $("#sector_id").append('<option value="' + row.sector_id + '">' + row.sector_name_en + '</option>'); });
                    });
                }
            });

            $("#sector_id").change(function () {
                var sectorId = $(this).val();
                $("#block_id").empty().append('<option value="">Select Block</option>');
                if(sectorId) {
                    $.get("/PropertyMaster/GetBlocks", { sectorId: sectorId }, function (data) {
                        $.each(data, function (i, row) { $("#block_id").append('<option value="' + row.block_id + '">' + row.block_name_en + '</option>'); });
                    });
                }
            });

            function loadModels() {
                $.get("/PropertyMaster/GetModels", function (data) {
                    var dropdown = $('#model_id');
                    dropdown.empty().append('<option value="">Select Model</option>');
                    $.each(data, function (i, item) { dropdown.append('<option value="' + item.id + '">' + item.name + '</option>'); });
                    if (currentModelId) dropdown.val(currentModelId);
                });
            }

            function loadUserCategory() {
                $.get("/PropertyMaster/GetUserCategory", function (data) {
                    var dropdown = $('#res_category_id');
                    dropdown.empty().append('<option value="">Select Category</option>');
                    $.each(data, function (i, item) { dropdown.append('<option value="' + item.id + '">' + item.name + '</option>'); });
                    if (currentCategoryId) dropdown.val(currentCategoryId);
                });
            }

            function loadFlats() {
                $.get("/PropertyMaster/GetFlats", function (data) {
                    $('#Flat_id').empty().append('<option value="">Select Flat</option>');
                    $.each(data, function (i, item) { $('#Flat_id').append('<option value="' + item.Flat_id + '">' + item.Flat_name_en + '</option>'); });
                    if (currentFlatId) $('#Flat_id').val(currentFlatId);
                });
            }

            function loadSectorsAndBlocksForEdit() {
                $.get("/PropertyMaster/GetSectors", { schemeId: currentSchemeId }, function (data) {
                    $("#sector_id").empty().append('<option value="">Select Sector</option>');
                    $.each(data, function (i, row) { $("#sector_id").append('<option value="' + row.sector_id + '">' + row.sector_name_en + '</option>'); });
                    $("#sector_id").val(currentSectorId);

                    $.get("/PropertyMaster/GetBlocks", { sectorId: currentSectorId }, function (bData) {
                        $("#block_id").empty().append('<option value="">Select Block</option>');
                        $.each(bData, function (i, row) { $("#block_id").append('<option value="' + row.block_id + '">' + row.block_name_en + '</option>'); });
                        $("#block_id").val(currentBlockId);
                    });
                });
            }
        });
    </script>
}