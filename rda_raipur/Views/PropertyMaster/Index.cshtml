@model IEnumerable<rda_raipur.Models.Property.TenderPropertyCreation>

@{
    ViewData["Title"] = "Master Inventory List";
    Layout = "~/Views/AdminShared/_AdminLayout.cshtml";
}

<link href="~/css/master-pages.css" rel="stylesheet" />
<link href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" rel="stylesheet" />

<div class="master-container">
    <div class="master-page-header">
        <h3 class="master-title text-capitalize">
            <i class='bx bx-buildings text-primary'></i>
            @if (ViewBag.CurrentScheme != null)
            {
                <span>Inventory: <span class="text-primary">@ViewBag.CurrentScheme</span></span>
            }
            else
            {
                <span>All Properties Inventory</span>
            }
        </h3>

        <div class="d-flex gap-2">
            <a asp-action="SchemeDashboard" class="btn btn-outline-secondary fw-bold rounded-pill px-4">
                <i class='bx bx-grid-alt me-1'></i> Back to Schemes
            </a>
            <a asp-action="Create" class="btn btn-primary fw-bold px-4 shadow-sm" style="background-color: #003366; border: none;">
                <i class='bx bx-plus-circle me-1'></i> Add Property
            </a>
        </div>
    </div>

    <div class="card master-card">
        <div class="card-body p-3">
            <div class="table-responsive">
                <table id="inventoryTable" class="table gov-table align-middle">
                    <thead>
                        <tr>
                            <th style="width: 60px;" class="text-center">S.No.</th>
                            <th>Property Code</th>
                            <th>Sector</th>
                            <th>Block</th>
                            <th>House No.</th>
                            <th>Config</th>
                            <th>Reservation</th>
                            <th>Offset Price (₹)</th>
                            <th class="text-center">Status</th>
                            <th class="text-center" style="width: 220px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            int serialNumber = 1;
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="text-center fw-bold text-muted">@serialNumber</td>
                                    <td class="fw-bold text-primary">@item.Property_Id</td>
                                    <td class="fw-bold text-dark">@item.sector_name_en</td>
                                    <td class="text-secondary fw-semibold">@item.block_name_en</td>
                                    <td class="fw-bold text-dark">@item.House_No</td>
                                    <td>
                                        <span class="fw-semibold">@item.Property_Type_Name_en</span>
                                        @if (!string.IsNullOrEmpty(item.Flat_name_en))
                                        {
                                            <span class="badge bg-light text-dark border ms-1 fw-bold">@item.Flat_name_en</span>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge bg-light text-danger border fw-bold px-2 py-1">
                                            @(item.res_category_name_en ?? "General")
                                        </span>
                                    </td>
                                    <td class="fw-bold text-success">
                                        @{
                                            decimal parsedPrice = 0;
                                            if (item.offset_Price != null) decimal.TryParse(item.offset_Price.ToString(), out parsedPrice);
                                        }
                                        ₹@parsedPrice.ToString("N0")
                                    </td>
                                    <td class="text-center">
                                        <span class="@(item.Booking_Status == "Vacant" ? "gov-badge-active" : "gov-badge-inactive")">
                                            @item.Booking_Status
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group btn-group-sm border rounded shadow-sm">
                                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-light text-info fw-bold" title="View">
                                                <i class='bx bx-show me-1'></i>View
                                            </a>
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-light text-primary fw-bold" title="Edit">
                                                <i class='bx bx-edit me-1'></i>Edit
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-light text-danger fw-bold" title="Delete">
                                                <i class='bx bx-trash me-1'></i>Delete
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                                serialNumber++;
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script>
        $(document).ready(function () {
            $('#inventoryTable').DataTable({
                "pageLength": 15,
                "lengthMenu": [[10, 15, 25, 50, -1], [10, 15, 25, 50, "All"]],
                "order": [[0, "asc"]],
                "responsive": true,
                "language": {
                    "search": "Quick Search: ",
                    "searchPlaceholder": "Type to filter records..."
                }
            });
        });
    </script>
}