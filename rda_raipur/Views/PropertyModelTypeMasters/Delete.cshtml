@model rda_raipur.Models.PropertyModelTypeMaster

@{
    ViewData["Title"] = "Delete Property Model Type";
    Layout = "~/Views/AdminShared/_AdminLayout.cshtml";
}

<link href="~/css/master-pages.css" rel="stylesheet" />

<div class="master-container">
    <div class="master-page-header">
        <h3 class="master-title"><i class="bi bi-trash3-fill text-danger"></i> Delete Property Model Type</h3>
        <a asp-action="Index" class="btn btn-outline-secondary fw-bold rounded-pill px-4">
            <i class="bi bi-arrow-left"></i> Back to List
        </a>
    </div>

    <div class="card master-card border-danger border-opacity-50">
        <div class="master-card-body p-4">

            <div class="alert alert-danger bg-danger bg-opacity-10 border-0 border-start border-danger border-4 fw-bold mb-4">
                <i class="bi bi-exclamation-triangle-fill fs-5 me-2 align-middle"></i>
                Are you sure you want to delete this property model type? This action cannot be undone.
            </div>

            <div class="row">
                <div class="col-md-6 detail-row">
                    <div class="detail-label">Model Name (English)</div>
                    <div class="detail-value text-danger fw-bold">@Model.Model_name_en</div>
                </div>
                <div class="col-md-6 detail-row">
                    <div class="detail-label">Model Name (Hindi)</div>
                    <div class="detail-value">@Model.Model_name_hi</div>
                </div>

                <div class="col-md-6 detail-row">
                    <div class="detail-label">Status</div>
                    <div class="detail-value">
                        @if (Model.IsActive == true)
                        {
                            <span class="gov-badge-active">Active</span>
                        }
                        else
                        {

                            <span class="gov-badge-inactive">Inactive</span>
                        }
                    </div>
                </div>
                <div class="col-md-6 detail-row">
                    <div class="detail-label">Is Deleted</div>
                    <div class="detail-value">
                        @if (Model.IsDeleted == true)
                        {
                            <span class="badge bg-danger">Yes</span>
                        }
                        else
                        {

                            <span class="badge bg-secondary">No</span>
                        }
                    </div>
                </div>

                <div class="col-md-6 detail-row border-bottom-0">
                    <div class="detail-label">Created Date</div>
                    <div class="detail-value">@(Model.Create_Date?.ToString("dd MMM yyyy, hh:mm tt") ?? "N/A")</div>
                    <span class="small text-muted d-block fw-normal">by @(string.IsNullOrEmpty(Model.created_by) ? "System" : Model.created_by)</span>
                </div>
                <div class="col-md-6 detail-row border-bottom-0">
                    <div class="detail-label">Last Updated</div>
                    <div class="detail-value">
                        @(Model.updated_Date?.ToString("dd MMM yyyy, hh:mm tt") ?? "N/A")
                        <span class="small text-muted d-block fw-normal">by @(string.IsNullOrEmpty(Model.updated_by) ? "System" : Model.updated_by)</span>
                    </div>
                </div>
            </div>

            <hr class="my-4 border-light">

            <form asp-action="Delete">
                <input type="hidden" asp-for="Model_Id" />
                <div class="d-flex justify-content-end gap-3">
                    <a asp-action="Index" class="btn btn-light border fw-bold px-4">Cancel</a>
                    <button type="submit" class="btn btn-danger fw-bold px-5 shadow-sm">
                        <i class="bi bi-trash"></i> Confirm Delete
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>