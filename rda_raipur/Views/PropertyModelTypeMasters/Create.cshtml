@model rda_raipur.Models.PropertyModelTypeMaster

@{
    ViewData["Title"] = "Add Property Model Type";
    Layout = "~/Views/AdminShared/_AdminLayout.cshtml";
}

<link href="~/css/master-pages.css" rel="stylesheet" />

<div class="master-container">
    <div class="master-page-header">
        <h3 class="master-title"><i class="bi bi-grid-fill text-primary"></i> Create Property Model Type</h3>
        <a asp-action="Index" class="btn btn-outline-secondary fw-bold rounded-pill px-4">
            <i class="bi bi-arrow-left"></i> Back to List
        </a>
    </div>

    <div class="card master-card">
        <div class="card-body p-4">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="All" class="text-danger fw-bold shadow-sm border-0 mb-4"></div>

                <div class="row">
                    <div class="col-md-6 form-group-spaced">
                        <label asp-for="Model_name_en" class="master-label">Model Name (English) <span class="text-danger">*</span></label>
                        <input asp-for="Model_name_en" class="master-input w-100" placeholder="e.g., Type A" required />
                        <span asp-validation-for="Model_name_en" class="text-danger small fw-bold"></span>
                    </div>

                    <div class="col-md-6 form-group-spaced">
                        <label asp-for="Model_name_hi" class="master-label">मॉडल का नाम (Hindi)</label>
                        <input asp-for="Model_name_hi" class="master-input w-100" placeholder="उदा. टाइप ए" />
                        <span asp-validation-for="Model_name_hi" class="text-danger small fw-bold"></span>
                    </div>

                    <div class="col-md-6 form-group-spaced">
                        <div class="d-flex gap-4 mt-3 pt-2">
                            <div class="form-check form-switch">
                                <input class="form-check-input fs-4" type="checkbox" name="IsActive" value="true" id="IsActiveSwitch" checked>
                                <label class="form-check-label fw-bold mt-1 ms-2" for="IsActiveSwitch">Is Active</label>
                            </div>
                            <div class="form-check form-switch" style="display:none;">
                                <input class="form-check-input fs-4" type="checkbox" name="IsDeleted" value="false" id="IsDeletedSwitch">
                            </div>
                        </div>
                    </div>
                </div>

                <hr class="my-4 border-light">

                <div class="d-flex justify-content-end gap-3">
                    <a asp-action="Index" class="btn btn-light border fw-bold px-4">Cancel</a>
                    <button type="submit" class="btn btn-primary fw-bold px-5 shadow-sm" style="background-color: #003366; border: none;">
                        <i class="bi bi-save me-1"></i> Save Model Type
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}