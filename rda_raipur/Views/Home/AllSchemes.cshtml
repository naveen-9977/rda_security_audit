@model IEnumerable<rda_raipur.Models.site.SiteScheme>
@using Microsoft.AspNetCore.Localization
@{
    var requestCulture = Context.Features.Get<IRequestCultureFeature>();
    bool isEnglish = (requestCulture?.RequestCulture.Culture.Name ?? "en").StartsWith("en");
    ViewData["Title"] = isEnglish ? "RDA Schemes & Projects" : "आरडीए योजनाएं एवं प्रोजेक्ट्स";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* 1. Page Background */
    .scheme-list-bg {
        background-color: #f4f7f6; /* Soft light background */
        padding-bottom: 80px;
        min-height: 80vh;
    }

    /* 2. Hero Header Section matching Details Page */
    .scheme-list-hero {
        background-color: #003366; /* Deep Blue */
        padding: 50px 0;
        color: #ffffff;
        border-bottom: 4px solid #FF9933; /* Saffron/Orange line */
        text-align: center;
        margin-bottom: 40px;
    }

    .hero-title {
        font-weight: 800;
        font-size: clamp(2rem, 3vw, 2.8rem);
        margin-bottom: 10px;
        letter-spacing: 0.5px;
    }

    .hero-subtitle {
        color: #cbd5e1;
        font-size: 1.1rem;
        font-weight: 500;
    }

    /* 3. Card Styling */
    .scheme-card-link {
        text-decoration: none;
        color: inherit;
        display: block;
        height: 100%;
        outline: none;
    }

    .scheme-card {
        background: #ffffff;
        border-radius: 12px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 4px 8px rgba(0,0,0,0.06); /* Soft subtle shadow */
        overflow: hidden;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        height: 100%;
        display: flex;
        flex-direction: column;
    }

    /* Card Hover Effects */
    .scheme-card-link:hover .scheme-card {
        transform: translateY(-8px); /* Card lifts up */
        box-shadow: 0 15px 30px rgba(0,0,0,0.12); /* Deeper shadow */
        border-bottom: 4px solid #FF9933; /* Orange accent appears at bottom */
    }

    /* 4. Image Wrapper & 🔥 MODERN SHIMMER LOADER 🔥 */
    .scheme-img-wrapper {
        height: 240px;
        overflow: hidden;
        position: relative;
        /* Shimmer Background */
        background: #e2e8f0;
        background: linear-gradient(90deg, #e2e8f0 25%, #f1f5f9 50%, #e2e8f0 75%);
        background-size: 200% 100%;
        animation: shimmerLoader 1.5s infinite;
    }

    @@keyframes shimmerLoader {
        0% {
            background-position: 200% 0;
        }

        100% {
            background-position: -200% 0;
        }
    }

    .scheme-img-wrapper img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        /* Image chhipi rahegi jab tak load na ho */
        opacity: 0;
        transition: opacity 0.6s ease-in-out, transform 0.5s ease;
    }

        /* Jab image load ho jayegi tab opacity 1 hogi */
        .scheme-img-wrapper img.loaded {
            opacity: 1;
        }

    /* Image zoom on hover */
    .scheme-card-link:hover .scheme-img-wrapper img.loaded {
        transform: scale(1.08);
    }

    /* 5. Card Body */
    .scheme-body {
        padding: 18px 15px;
        flex-grow: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        background-color: #ffffff;
    }

    .scheme-title {
        color: #003366;
        font-weight: 700;
        font-size: 1.15rem;
        margin-bottom: 0;
        transition: color 0.3s;
        line-height: 1.3;
        letter-spacing: 0.3px;
        text-transform: capitalize;
    }

    .scheme-card-link:hover .scheme-title {
        color: #FF9933;
    }
</style>

<div class="scheme-list-hero">
    <div class="container-fluid px-md-5">
        <h1 class="hero-title">@(isEnglish ? "RDA Schemes & Projects" : "आरडीए योजनाएं एवं प्रोजेक्ट्स")</h1>
        <p class="hero-subtitle">@(isEnglish ? "Explore our latest town planning and development initiatives." : "हमारी नवीनतम नगर नियोजन और विकास पहलों का अन्वेषण करें।")</p>
    </div>
</div>

<div class="scheme-list-bg">
    <div class="container-fluid px-md-5">
        <div class="row g-4 justify-content-center">

            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    // Slug URL ke liye (space ko '-' mein badalna)
                    var schemeSlug = item.SchemeName.Replace(" ", "-");

                    <div class="col-12 col-md-6 col-lg-4 col-xl-3">
                        <a asp-action="SchemeDetails" asp-route-name="@schemeSlug" class="scheme-card-link">
                            <div class="scheme-card">
                                <div class="scheme-img-wrapper">
                                    <img src="@(!string.IsNullOrEmpty(item.ImagePath) ? item.ImagePath : "/images/placeholder.jpg")" alt="@item.SchemeName" loading="lazy" onload="this.classList.add('loaded')">
                                </div>
                                <div class="scheme-body">
                                    <h3 class="scheme-title">@item.SchemeName</h3>
                                </div>
                            </div>
                        </a>
                    </div>
                }
            }
            else
            {
                <div class="col-12 col-md-6 col-lg-4 col-xl-3">
                    <a asp-action="SchemeDetails" asp-route-name="Kamal-Vihar-Scheme" class="scheme-card-link">
                        <div class="scheme-card">
                            <div class="scheme-img-wrapper">
                                <img src="https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?q=80&w=2070&auto=format&fit=crop" alt="Demo Scheme" loading="lazy" onload="this.classList.add('loaded')">
                            </div>
                            <div class="scheme-body">
                                <h3 class="scheme-title">Kamal Vihar Development Scheme</h3>
                            </div>
                        </div>
                    </a>
                </div>
            }

        </div>
    </div>
</div>