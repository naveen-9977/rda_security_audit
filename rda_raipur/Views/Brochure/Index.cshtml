@using rda_raipur.Data
@using System.Security.Claims
@inject ApplicationDbContext _context
@model IEnumerable<rda_raipur.Models.Brochure>

@{
    Layout = "~/Views/AdminShared/_AdminLayout.cshtml";
    ViewData["Title"] = "Manage Brochures";

    // ==========================================
    // PERMISSION LOGIC FOR UI BUTTONS
    // ==========================================
    var userIdStr = User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
    int userId = 0;
    int.TryParse(userIdStr, out userId);

    bool isAdmin = User.IsInRole("Admin");

    // Default permissions (Admin has everything)
    bool canAdd = isAdmin;
    bool canEdit = isAdmin;
    bool canDelete = isAdmin;

    // Agar Admin nahi hai, toh DB se specific permissions check karein
    if (!isAdmin && userId > 0)
    {
        var permission = (from p in _context.EmployeePermissions
                          join m in _context.AppModules on p.ModuleId equals m.ModuleId
                          where p.UserId == userId && m.ControllerName == "Brochure"
                          select p).FirstOrDefault();

        if (permission != null)
        {
            canAdd = permission.CanAdd;
            canEdit = permission.CanEdit;
            canDelete = permission.CanDelete;
        }
    }
}

<div class="card shadow-sm mt-4">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h4 class="mb-0">Manage Brochures</h4>

        @* 🔥 Sirf tab dikhao jab Add permission ho *@
        @if (canAdd)
        {
            <a href="@Url.Action("Create")" class="btn btn-light btn-sm text-primary font-weight-bold">
                <i class="bx bx-plus"></i> Add New Brochure
            </a>
        }
    </div>
    <div class="card-body">

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bx bx-check-circle"></i> @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="table-responsive">
            <table class="table table-bordered table-hover align-middle text-center">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Image</th>
                        <th>Title (English)</th>
                        <th>Title (Hindi)</th>
                        <th>PDF Document</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        int count = 1;
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@count</td>
                                <td>
                                    <img src="@item.ImagePath" alt="Thumbnail" style="width: 80px; height: 50px; object-fit: cover; border-radius: 4px;" />
                                </td>
                                <td>@item.Title_En</td>
                                <td>@item.Title_Hi</td>
                                <td>
                                    <a href="@item.PdfPath" target="_blank" class="btn btn-sm btn-outline-danger">
                                        <i class="bx bxs-file-pdf"></i> View PDF
                                    </a>
                                </td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactive</span>
                                    }
                                </td>
                                <td>
                                    @* 🔥 Sirf tab dikhao jab Edit permission ho *@
                                    @if (canEdit)
                                    {
                                        <a href="@Url.Action("Edit", new { id = item.Id })" class="btn btn-sm btn-warning">
                                            <i class="bx bx-edit"></i> Edit
                                        </a>
                                    }

                                    @* 🔥 Sirf tab dikhao jab Delete permission ho *@
                                    @if (canDelete)
                                    {
                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline;">
                                            <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Are you sure?');">
                                                <i class="bx bx-trash"></i> Delete
                                            </button>
                                        </form>
                                    }

                                    @if (!canEdit && !canDelete)
                                    {
                                        <span class="text-muted small">No Permission</span>
                                    }
                                </td>
                            </tr>
                            count++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">No brochures found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>