@model rda_raipur.Models.Brochure
@{
    Layout = "~/Views/AdminShared/_AdminLayout.cshtml";
    ViewData["Title"] = "Edit Brochure";
}

<div class="card shadow-sm mt-4">
    <div class="card-header bg-warning text-dark">
        <h4 class="mb-0">Edit Brochure</h4>
    </div>
    <div class="card-body">

        <div asp-validation-summary="All" class="text-danger mb-3 font-weight-bold"></div>

        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="CreatedDate" />

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="font-weight-bold">Title (English) <span class="text-danger">*</span></label>
                    <input asp-for="Title_En" class="form-control" required />
                    <span asp-validation-for="Title_En" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="font-weight-bold">Title (Hindi) <span class="text-danger">*</span></label>
                    <input asp-for="Title_Hi" class="form-control" required />
                    <span asp-validation-for="Title_Hi" class="text-danger"></span>
                </div>
            </div>

            <div class="row mt-3">
                <div class="col-md-6 mb-3">
                    <label class="font-weight-bold">Upload New Thumbnail Image</label>
                    <input type="file" name="imageFile" class="form-control" accept="image/jpeg, image/png, image/jpg" />
                    <small class="text-muted">Leave blank if you don't want to change the image.</small>
                    
                    @if (!string.IsNullOrEmpty(Model.ImagePath))
                    {
                        <div class="mt-2">
                            <p class="mb-1"><strong>Current Image:</strong></p>
                            <img src="@Model.ImagePath" alt="Current Image" style="max-height: 100px; border-radius:5px; border:1px solid #ccc;" />
                        </div>
                    }
                </div>

                <div class="col-md-6 mb-3">
                    <label class="font-weight-bold">Upload New Brochure PDF</label>
                    <input type="file" name="pdfFile" class="form-control" accept=".pdf" />
                    <small class="text-muted">Leave blank if you don't want to change the PDF.</small>

                    @if (!string.IsNullOrEmpty(Model.PdfPath))
                    {
                        <div class="mt-2">
                            <p class="mb-1"><strong>Current PDF:</strong></p>
                            <a href="@Model.PdfPath" target="_blank" class="btn btn-sm btn-outline-danger"><i class='bx bxs-file-pdf'></i> View Current PDF</a>
                        </div>
                    }
                </div>
            </div>

            <div class="form-group mt-3">
                <div class="custom-control custom-switch">
                    <input asp-for="IsActive" class="custom-control-input" type="checkbox" id="customSwitch1">
                    <label class="custom-control-label" for="customSwitch1">Is Active (Show on Website)</label>
                </div>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-warning"><i class="bx bx-edit"></i> Update Brochure</button>
                <a href="@Url.Action("Index")" class="btn btn-secondary ms-2"><i class="bx bx-arrow-back"></i> Back to List</a>
            </div>
            
        </form>
    </div>
</div>