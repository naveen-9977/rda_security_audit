@model rda_raipur.Models.Brochure
@{
    Layout = "~/Views/AdminShared/_AdminLayout.cshtml"; // Ensure this path matches your layout
    ViewData["Title"] = "Add New Brochure";
}

<div class="card shadow-sm mt-4">
    <div class="card-header bg-primary text-white">
        <h4 class="mb-0">Add New Brochure</h4>
    </div>
    <div class="card-body">

        <div asp-validation-summary="All" class="text-danger mb-3 font-weight-bold"></div>

        <form asp-action="Create" method="post" enctype="multipart/form-data">

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="font-weight-bold">Title (English) <span class="text-danger">*</span></label>
                    <input asp-for="Title_En" class="form-control" required placeholder="e.g. Kaushalya Mata Vihar" />
                    <span asp-validation-for="Title_En" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="font-weight-bold">Title (Hindi) <span class="text-danger">*</span></label>
                    <input asp-for="Title_Hi" class="form-control" required placeholder="उदा. कौशल्या माता विहार" />
                    <span asp-validation-for="Title_Hi" class="text-danger"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="font-weight-bold">Upload Thumbnail Image <span class="text-danger">*</span></label>
                    <input type="file" name="imageFile" class="form-control" accept="image/jpeg, image/png, image/jpg" required />
                    <small class="text-muted">Recommended: JPG/PNG format.</small>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="font-weight-bold">Upload Brochure PDF <span class="text-danger">*</span></label>
                    <input type="file" name="pdfFile" class="form-control" accept=".pdf" required />
                    <small class="text-muted">Only PDF files are allowed.</small>
                </div>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-success"><i class="bx bx-save"></i> Save Brochure</button>
                <a href="@Url.Action("Index")" class="btn btn-secondary ms-2"><i class="bx bx-arrow-back"></i> Back to List</a>
            </div>

        </form>
    </div>
</div>