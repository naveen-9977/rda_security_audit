@using Microsoft.AspNetCore.Localization
@model rda_raipur.Models.ViewModels.BookingFormViewModel

@{
    var requestCulture = Context.Features.Get<IRequestCultureFeature>();
    var culture = requestCulture?.RequestCulture.Culture.Name ?? System.Threading.Thread.CurrentThread.CurrentUICulture.Name;
    bool isEng = culture.StartsWith("en");

    // 🔥 FIXED: Language logic is now dynamic 🔥
    ViewBag.IsEnglish = isEng;

    ViewBag.UnitNo = ViewBag.UnitNo ?? "N/A";
    ViewBag.EmdAmount = ViewBag.EmdAmount ?? "0";
    ViewBag.PropertyName = ViewBag.PropertyName ?? "Kaushalya Mata Vihar";
    ViewBag.Sector = ViewBag.Sector ?? "N/A";
    ViewBag.AssetNo = ViewBag.AssetNo ?? ViewBag.UnitNo;
    ViewBag.Category = ViewBag.Category ?? "Residential";
    ViewBag.ReserveCategory = ViewBag.ReserveCategory ?? "Unreserved";
    ViewBag.Area = ViewBag.Area ?? "0.00";
    ViewBag.TotalPrice = ViewBag.TotalPrice ?? "0";
    ViewBag.Location = ViewBag.Location ?? "N/A";

    // 🔥 NAYA LOGIC: Property Type ke anusaar Unit No. ka naam badalna 🔥
    string propType = ViewBag.Category?.ToString()?.ToLower() ?? "";
    string unitLabel = isEng ? "Unit No." : "यूनिट नं."; // Default

    if (propType.Contains("flat"))
    {
        unitLabel = isEng ? "Flat No." : "फ्लैट क्र.";
    }
    else if (propType.Contains("plot") || propType.Contains("land"))
    {
        unitLabel = isEng ? "Plot No." : "प्लॉट (भूखंड) क्र.";
    }
    else if (propType.Contains("shop") || propType.Contains("commercial"))
    {
        unitLabel = isEng ? "Shop No." : "दुकान क्र.";
    }
    else if (propType.Contains("house") || propType.Contains("makan"))
    {
        unitLabel = isEng ? "House No." : "मकान क्र.";
    }

    // Ise hum _PropertyInfo.cshtml jaise Partial Views me use karenge
    ViewBag.UnitLabel = unitLabel;

    ViewData["Title"] = "Application Form";
    Layout = "~/Views/Shared/_Layout.cshtml";

    // Path folder set kiya gaya hai
    string partialPath = "Booking/";
}

<partial name="@(partialPath + "_BookingStyles")" />

@* 🔥 FIXED WIDTH & OFFICIAL GOVT LOOK STYLING 🔥 *@
<style>
    :root {
        --govt-primary: #003366; /* Official Navy Blue */
        --govt-secondary: #e88d14; /* Saffron/Orange accent */
        --govt-bg: #f4f6f9; /* Clean light gray */
        --govt-text: #333333;
        --govt-border: #dee2e6;
    }

    body {
        background-color: var(--govt-bg) !important;
    }

    .govt-page-bg {
        background-color: var(--govt-bg);
        min-height: 100vh;
        padding: 30px 0;
    }

    /* 🔥 Width locked to 1350px to prevent stretching 🔥 */
    .form-fixed-wrapper {
        max-width: 1350px;
        margin: 0 auto;
        width: 100%;
    }

    .govt-form-container {
        background: #ffffff;
        border-radius: 4px;
        border: 1px solid var(--govt-border);
        border-top: 4px solid var(--govt-primary); /* Govt Navy Blue Border */
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        overflow: hidden;
    }

    .govt-page-header {
        background: #f8f9fa; /* Light Gray Header */
        color: var(--govt-primary);
        padding: 20px 30px;
        border-bottom: 1px solid var(--govt-border);
    }

        .govt-page-header h4 {
            margin: 0;
            font-weight: 700;
            font-size: 1.4rem;
            letter-spacing: 0.5px;
            text-transform: uppercase;
        }

    .btn-govt-back {
        background: #ffffff;
        color: var(--govt-primary);
        border: 1px solid var(--govt-primary);
        font-weight: 600;
        border-radius: 2px;
        transition: 0.2s;
    }

        .btn-govt-back:hover {
            background: var(--govt-primary);
            color: #ffffff;
        }

    .btn-govt-preview {
        background: #28a745; /* Official Govt Green */
        color: #ffffff;
        border: none;
        font-weight: 600;
        border-radius: 2px;
        transition: 0.2s;
        text-transform: uppercase;
    }

        .btn-govt-preview:hover {
            background: #218838;
            color: #ffffff;
        }
</style>

<div class="govt-page-bg">
    <div class="container-fluid">
        <div class="form-fixed-wrapper">
            <div class="govt-form-container shadow-sm">

                <div class="govt-page-header text-center">
                    <h4>@(ViewBag.IsEnglish ? "Property Booking Application" : "संपत्ति बुकिंग आवेदन")</h4>
                    <div class="mt-1 fw-bold text-secondary" style="font-size: 13px;">
                        <i class="bi bi-geo-alt-fill text-danger"></i> @(ViewBag.IsEnglish ? "Project / Scheme:" : "परियोजना / योजना:") <span class="text-dark">@Html.Raw(ViewBag.Location)</span>
                    </div>
                </div>

                <partial name="@(partialPath + "_PropertyInfo")" />

               
                <form id="bookingForm" onsubmit="return false;" enctype="multipart/form-data" autocomplete="off">

                    <input type="hidden" id="hidden-asset-no" value="@ViewBag.AssetNo" />
                    <input type="hidden" id="hidden-base-price" value="@ViewBag.TotalPrice" />
                    <input type="hidden" id="hidden-emd-amount" value="@ViewBag.EmdAmount" />

                    <div id="form-entry-section">
                        <partial name="@(partialPath + "_MobileVerification")" />

                        <div id="main-application-form" class="disabled-section">

                            <partial name="@(partialPath + "_ApplicantDetails")" />

                            <partial name="@(partialPath + "_DocumentUploads")" />

                            <div class="text-center p-3 bg-light border-top d-flex justify-content-center gap-3">
                                <a href="javascript:history.back()" class="btn btn-govt-back d-flex align-items-center px-4" style="height: 38px !important; font-size: 14px !important;">
                                    <i class='bx bx-arrow-back me-2'></i> @(ViewBag.IsEnglish ? "Back to Properties" : "संपत्तियों पर वापस जाएं")
                                </a>
                                <button type="button" class="btn btn-govt-preview d-flex align-items-center px-4" style="height: 38px !important; font-size: 14px !important;" onclick="showPreviewSection()">
                                    <i class='bx bx-search-alt-2 me-2'></i> @(ViewBag.IsEnglish ? "Preview Application" : "आवेदन का पूर्वावलोकन")
                                </button>
                            </div>
                        </div>
                    </div>

                    <partial name="@(partialPath + "_ApplicationPreview")" />

                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="@(partialPath + "_BookingScripts")" />
}