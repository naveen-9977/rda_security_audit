<div class="terms-container" style="padding-top: 20px;">
    <div style="text-align: center; margin-bottom: 20px; border-bottom: 2px solid #000; padding-bottom: 10px;">
        <h3 style="margin: 0; font-size: 20px; font-weight: 900; text-transform: uppercase;">नियम व शर्तें (Terms & Conditions)</h3>
    </div>

    <ul style="font-size: 12px; line-height: 1.5; color: #000; text-align: justify; padding-left: 20px; margin-top: 10px;">
        <li style="margin-bottom: 6px;">
            <strong>नागरिकता एवं प्रपत्र:</strong> निविदादाता भारत का नागरिक होना अनिवार्य है। प्रत्येक सम्पत्ति के लिए अलग-अलग निविदा प्रपत्र भरना होगा।
        </li>
        <li style="margin-bottom: 6px;">
            <strong>आवेदन शुल्क:</strong> निविदा प्रपत्र का मूल्य रूप्ए 500/- है। निविदा प्रपत्र की राशि का न तो समायोजन किया जाएगा और ना ही यह राशि वापस की जाएगी।
        </li>
        <li style="margin-bottom: 6px;">
            <strong>धरोहर राशि (EMD) रिफंड:</strong> निविदा अस्वीकृत होने या अन्य कारणों से यदि धरोहर राशि (EMD) वापस की जाती है, तो यह रिफंड उसी पेमेंट माध्यम (Payment Gateway) से किया जाएगा जिससे भुगतान हुआ है। RTGS/NEFT की स्थिति में रिफंड फॉर्म में भरे गए बैंक खाते में ही ट्रांसफर होगा।
        </li>
        <li style="margin-bottom: 6px;">
            <strong>न्यूनतम दर एवं समान दरें (Tie):</strong> आरक्षित मूल्य (ऑफसेट दर) से कम राशि का प्रस्ताव स्वीकार नहीं किया जाएगा। एक जैसी समान दरें प्राप्त होने पर स्वीकृति लॉटरी के आधार पर की जाएगी।
        </li>
        <li style="margin-bottom: 6px;">
            <strong>भुगतान एवं विलम्ब:</strong> आवंटन आदेश के अनुसार निर्धारित समय में राशि का भुगतान करना होगा। विलम्ब की स्थिति में 12% (बारह प्रतिशत) सरचार्ज देय होगा। भुगतान नहीं होने पर बिना पूर्व सूचना के आवंटन निरस्त माना जाएगा।
        </li>
        <li style="margin-bottom: 6px;">
            <strong>रजिस्ट्री एवं कब्जा:</strong> सम्पूर्ण भुगतान के उपरान्त निविदादाता को एक माह में स्टॉम्प मूल्य पर स्वयं के व्यय पर विक्रय विलेख/पट्टा विलेख / रजिस्ट्री कराना होगा। दस्तावेज की फोटोप्रति जमा कराने के बाद ही सम्पत्ति का कब्जा दिया जाएगा।
        </li>
        <li style="margin-bottom: 6px;">
            <strong>छत पर अधिकार एवं विभाजन:</strong> विक्रित सम्पत्ति में दुकान, फ्लैट या हॉल की छत (Roof) पर आबंटिती का कोई अधिकार नहीं होगा। सम्पत्ति का किसी भी प्रकार से विभाजन कर विक्रय नहीं किया जा सकेगा।
        </li>
        <li style="margin-bottom: 6px;">
            <strong>प्रतिबंधित गतिविधियां:</strong> सम्पत्ति में मादक पदार्थ, ज्वलनशील सामग्री, प्रदूषण या शोर करने वाला कोई भी प्रतिबंधित व्यवसाय पूर्णतः वर्जित है। ऐसा पाए जाने पर आवंटन रद्द कर दिया जाएगा।
        </li>
        <li style="margin-bottom: 6px;">
            <strong>संधारण (Maintenance) समिति:</strong> आवासीय या व्यावसायिक परिसर के रखरखाव, साफ-सफाई आदि के लिए आवंटितियों को 18 माह के भीतर एक समिति का गठन कर उसका पंजीयन कराना अनिवार्य होगा।
        </li>
        <li style="margin-bottom: 6px;">
            <strong>भू-भाटक (Ground Rent):</strong> लीज पर आबंटित सम्पत्तियों के लिए नियमानुसार हर वर्ष 10 जून तक निर्धारित भू-भाटक जमा करना अनिवार्य है, विलम्ब होने पर 12% वार्षिकी सरचार्ज लगेगा।
        </li>
        <li style="margin-bottom: 6px;">
            <strong>बैंक ऋण (Bank Loan):</strong> सम्पत्ति क्रय हेतु यदि आवंटिती बैंक से ऋण लेना चाहता है, तो प्राधिकरण द्वारा ट्राई पार्टी एग्रीमेन्ट (Tri-party Agreement) किए जाने का प्रावधान है।
        </li>
        <li style="margin-bottom: 6px;">
            <strong>टीडीएस (TDS) कटौती:</strong> यदि निविदादाता 50 लाख रूपये से अधिक की सम्पत्ति क्रय करता है, तो उसे आयकर अधिनियम 1941A के तहत कुल राशि का 1% TDS रायपुर विकास प्राधिकरण के PAN (AAALR010712) पर जमा कर चालान की प्रति कार्यालय में देना अनिवार्य है।
        </li>
        <li style="margin-bottom: 6px;">
            <strong>निरीक्षण एवं दलाल:</strong> निविदा भरने से पूर्व सम्पत्ति का स्थल निरीक्षण स्वयं कर लें। प्राधिकरण ने सम्पत्ति विक्रय हेतु किसी भी ब्रोकर या दलाल की नियुक्ति नहीं की है।
        </li>
    </ul>

    <!-- 🔥 DECLARATION SECTION 🔥 -->
    <div style="margin-top: 25px; padding: 12px 15px; background-color: #f1f5f9; border-left: 4px solid #198754; border-radius: 4px;">
        <p style="margin: 0; font-size: 13px; font-weight: 800; color: #000;">
            घोषणा (Declaration):
        </p>
        <p style="margin: 5px 0 0 0; font-size: 12px; color: #333; text-align: justify; line-height: 1.5;">
            मैं यह घोषणा करता/करती हूँ कि मैंने रायपुर विकास प्राधिकरण द्वारा निर्धारित ऊपर दिए गए सभी निर्देशों, नियमों और शर्तों को ध्यानपूर्वक पढ़ और समझ लिया है। मैं इन सभी नियमों व शर्तों से पूर्णतः सहमत हूँ और यह ऑनलाइन आवेदन मेरी पूर्ण सहमति से प्रस्तुत किया गया है।
        </p>
    </div>

    <!-- 🔥 APPLICANT SIGNATURE SECTION 🔥 -->
    <div style="margin-top: 30px; text-align: right; padding-right: 20px;">
        <div style="display: inline-block; text-align: center;">
            <div style="width: 140px; height: 50px; border-bottom: 1.5px solid #000; display: flex; align-items: flex-end; justify-content: center; margin-bottom: 5px; padding-bottom: 2px;">
                @if (!string.IsNullOrEmpty(ViewBag.SignPath))
                {
                    <img src="@ViewBag.SignPath" alt="Signature" crossorigin="anonymous" style="max-width: 100%; max-height: 100%; object-fit: contain;" />
                }
                else
                {
                    <span style="font-size:10px; color:#888;">SIGNATURE</span>
                }
            </div>
            <p style="margin: 0; font-size: 13px; font-weight: bold; color: #000;">आवेदक के हस्ताक्षर</p>
            <p style="margin: 0; font-size: 11px; color: #555;">(Applicant Signature)</p>
        </div>
    </div>
</div>