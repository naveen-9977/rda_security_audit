@model rda_raipur.Models.AllotmentType_Master

@{
    ViewData["Title"] = "Allotment Type Details";
    Layout = "~/Views/AdminShared/_AdminLayout.cshtml";
}

<link href="~/css/master-pages.css" rel="stylesheet" />

<div class="master-container">
    <div class="master-page-header">
        <h3 class="master-title"><i class="fas fa-info-circle text-primary"></i> Allotment Type Details</h3>
        <a asp-action="Index" class="btn btn-outline-secondary fw-bold rounded-pill px-4">
            <i class="fas fa-arrow-left"></i> Back to List
        </a>
    </div>

    <div class="card master-card">
        <div class="card-body p-4">

            <div class="mb-4">
                <div class="detail-row">
                    <div class="row">
                        <div class="col-md-4 detail-label">Allotment Name (Hindi)</div>
                        <div class="col-md-8 detail-value">@Model.allotement_type_name_hi</div>
                    </div>
                </div>
                <div class="detail-row">
                    <div class="row">
                        <div class="col-md-4 detail-label">Allotment Name (English)</div>
                        <div class="col-md-8 detail-value">@Model.allotement_type_name_en</div>
                    </div>
                </div>
                <div class="detail-row">
                    <div class="row">
                        <div class="col-md-4 detail-label">Created By</div>
                        <div class="col-md-8 detail-value">@(Model.created_by ?? "N/A")</div>
                    </div>
                </div>
                <div class="detail-row">
                    <div class="row">
                        <div class="col-md-4 detail-label">Creation Date</div>
                        <div class="col-md-8 detail-value">
                            @(Model.Create_Date?.ToString("dd MMM yyyy HH:mm") ?? "N/A")
                        </div>
                    </div>
                </div>
                <div class="detail-row">
                    <div class="row">
                        <div class="col-md-4 detail-label">Last Updated By</div>
                        <div class="col-md-8 detail-value">@(Model.updated_by ?? "N/A")</div>
                    </div>
                </div>
                <div class="detail-row">
                    <div class="row">
                        <div class="col-md-4 detail-label">Last Update Date</div>
                        <div class="col-md-8 detail-value">
                            @(Model.updated_Date?.ToString("dd MMM yyyy HH:mm") ?? "N/A")
                        </div>
                    </div>
                </div>
                <div class="detail-row">
                    <div class="row">
                        <div class="col-md-4 detail-label">Status</div>
                        <div class="col-md-8 detail-value">
                            <span class="@(Model.IsActive == true ? "gov-badge-active" : "gov-badge-inactive")">
                                @(Model.IsActive == true ? "Active" : "Inactive")
                            </span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-end gap-3 mt-4">
                <a asp-action="Edit" asp-route-id="@Model?.allotement_type_id" class="btn btn-primary fw-bold px-4" style="background-color: #003366; border: none;">
                    <i class="fas fa-edit me-1"></i> Edit Record
                </a>
                <a asp-action="Index" class="btn btn-light border fw-bold px-4">Back to List</a>
            </div>
        </div>
    </div>
</div>