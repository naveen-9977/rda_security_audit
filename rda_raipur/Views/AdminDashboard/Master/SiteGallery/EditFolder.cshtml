@model rda_raipur.Models.site.GalleryFolder
@{
    ViewData["Title"] = "Edit Album";
    Layout = "~/Views/AdminShared/_AdminLayout.cshtml";
}

<link href="~/css/master-pages.css" rel="stylesheet" />

<div class="master-container">
    <div class="master-page-header">
        <h3 class="master-title"><i class="bi bi-pencil-square text-primary"></i> Edit Album / Folder</h3>
        <a asp-action="Index" class="btn btn-outline-secondary fw-bold rounded-pill px-4">
            <i class="bi bi-arrow-left"></i> Back to List
        </a>
    </div>

    <div class="card master-card">
        <div class="card-body p-4">
            <form asp-action="EditFolder" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />

                <div class="row">
                    <div class="col-md-12 form-group-spaced">
                        <label asp-for="FolderName" class="master-label">Album Name <span class="text-danger">*</span></label>
                        <input asp-for="FolderName" class="master-input" required />
                    </div>

                    <div class="col-12 form-group-spaced">
                        <div class="form-check form-switch mt-2">
                            <input class="form-check-input fs-4" asp-for="IsActive" id="IsActive">
                            <label class="form-check-label fw-bold mt-1 ms-2" for="IsActive">Active Status</label>
                        </div>
                    </div>

                    <div class="col-md-12 form-group-spaced">
                        <label class="master-label d-block">Current Cover</label>
                        @if (!string.IsNullOrEmpty(Model.CoverImagePath))
                        {
                            <img src="@Model.CoverImagePath" class="img-thumbnail shadow-sm mb-3" style="height: 120px;" />
                        }
                        <label asp-for="CoverImageUpload" class="master-label">Replace Cover (Optional)</label>
                        <input asp-for="CoverImageUpload" type="file" class="master-input p-1" accept="image/*" />
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-3 mt-4">
                    <a asp-action="Index" class="btn btn-light border fw-bold px-4">Cancel</a>
                    <button type="submit" class="btn btn-primary fw-bold px-5 shadow-sm">Update Album</button>
                </div>
            </form>
        </div>
    </div>
</div>