@model rda_raipur.Models.site.GalleryFolder
@{
    ViewData["Title"] = "Edit Gallery Album";
    Layout = "~/Views/AdminShared/_AdminLayout.cshtml";
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-md-6 mx-auto">
            <div class="card shadow">
                <div class="card-header bg-warning text-dark d-flex justify-content-between">
                    <h5 class="mb-0">Edit Album / Folder</h5>
                    <a href="@Url.Action("Index", "SiteGallery")" class="btn btn-light btn-sm">Back to List</a>
                </div>
                <div class="card-body">
                    <form asp-action="EditFolder" method="post" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <input type="hidden" asp-for="Id" />

                        <div class="mb-3">
                            <label asp-for="FolderName" class="form-label">Album / Folder Name <span class="text-danger">*</span></label>
                            <input asp-for="FolderName" class="form-control" required />
                            <span asp-validation-for="FolderName" class="text-danger"></span>
                        </div>

                        <div class="mb-3 form-check form-switch">
                            <input class="form-check-input" type="checkbox" asp-for="IsActive">
                            <label class="form-check-label" asp-for="IsActive">Active Status</label>
                        </div>

                        <div class="mb-3">
                            <label class="form-label d-block">Current Cover Image</label>
                            @if (!string.IsNullOrEmpty(Model.CoverImagePath))
                            {
                                <img src="@Model.CoverImagePath" class="img-thumbnail mb-2" style="height: 120px;" />
                            }
                            else
                            {
                                <p class="text-muted small">No cover image uploaded.</p>
                            }

                            <input asp-for="CoverImageUpload" type="file" class="form-control" accept="image/*" />
                            <small class="text-muted">Leave empty to keep the current image.</small>
                        </div>

                        <hr />
                        <button type="submit" class="btn btn-success px-4">Update Album</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>