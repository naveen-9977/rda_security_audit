@model IEnumerable<rda_raipur.Models.site.SiteGallery>
@using rda_raipur.Data
@using System.Security.Claims
@inject ApplicationDbContext _context

@{
    ViewData["Title"] = "Gallery Management";
    Layout = "~/Views/AdminShared/_AdminLayout.cshtml";

    // --- Permission Logic ---
    var userIdStr = User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
    int userId = 0;
    int.TryParse(userIdStr, out userId);
    bool isAdmin = User.IsInRole("Admin");

    var permission = (from p in _context.EmployeePermissions
                      join m in _context.AppModules on p.ModuleId equals m.ModuleId
                      where p.UserId == userId && m.ControllerName == "SiteGallery"
                      select p).FirstOrDefault();

    bool canAdd = isAdmin || (permission?.CanAdd ?? false);
    bool canEdit = isAdmin || (permission?.CanEdit ?? false);
    bool canDelete = isAdmin || (permission?.CanDelete ?? false);

    var folders = ViewBag.FoldersList as IEnumerable<rda_raipur.Models.site.GalleryFolder>;
    var activeTab = TempData["ActiveTab"]?.ToString() ?? "images";
}

<link href="~/css/master-pages.css" rel="stylesheet" />
<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />

<div class="master-container">
    <div class="master-page-header">
        <h2 class="master-title">
            <i class="bi bi-images text-primary me-2"></i> Photo Gallery Master
        </h2>
    </div>

    <div class="card master-card">
        <div class="card-body p-3">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
                    <i class="bi bi-check-circle me-1"></i> @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <ul class="nav nav-tabs mb-4" id="galleryTab" role="tablist">
                <li class="nav-item">
                    <button class="nav-link @(activeTab == "images" ? "active" : "") fw-bold" id="images-tab" data-bs-toggle="tab" data-bs-target="#images" type="button">
                        <i class="bi bi-image me-1"></i> Gallery Images
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link @(activeTab == "folders" ? "active" : "") fw-bold" id="folders-tab" data-bs-toggle="tab" data-bs-target="#folders" type="button">
                        <i class="bi bi-folder me-1"></i> Manage Albums (Folders)
                    </button>
                </li>
            </ul>

            <div class="tab-content" id="galleryTabContent">
                <div class="tab-pane fade @(activeTab == "images" ? "show active" : "")" id="images" role="tabpanel">
                    <div class="d-flex justify-content-end mb-3">
                        @if (canAdd)
                        {
                            <a href="@Url.Action("Create", "SiteGallery")" class="btn btn-primary fw-bold shadow-sm px-4">
                                <i class="bi bi-plus-circle me-1"></i> Add New Image
                            </a>
                        }
                    </div>

                    <div class="table-responsive">
                        <table id="imagesTable" class="table gov-table align-middle">
                            <thead>
                                <tr>
                                    <th style="width: 100px;">Preview</th>
                                    <th>Album / Folder</th>
                                    <th>Title (English)</th>
                                    <th>Title (Hindi)</th>
                                    <th class="text-center">Status</th>
                                    <th class="text-center" width="180">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model != null)
                                {
                                    foreach (var item in Model)
                                    {
                                        <tr>
                                            <td>
                                                <img src="@item.ImagePath" class="img-thumbnail" style="height: 50px; width: 80px; object-fit: cover; cursor: pointer;" onerror="this.src='/images/placeholder.png'" />
                                            </td>
                                            <td class="fw-bold">@(item.GalleryFolder?.FolderName ?? "Uncategorized")</td>
                                            <td>@item.Title_en</td>
                                            <td>@item.Title_hi</td>
                                            <td class="text-center">
                                                <span class="@(item.IsActive ? "gov-badge-active" : "gov-badge-inactive")">
                                                    @(item.IsActive ? "Active" : "Inactive")
                                                </span>
                                            </td>
                                            <td class="text-center">
                                                <div class="btn-group shadow-sm">
                                                    @if (canEdit)
                                                    {
                                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                                            <i class="bi bi-pencil-square"></i> Edit
                                                        </a>
                                                    }
                                                    @if (canDelete)
                                                    {
                                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline;" onsubmit="return confirm('Delete this image?');">
                                                            @Html.AntiForgeryToken()
                                                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                                                <i class="bi bi-trash"></i> Delete
                                                            </button>
                                                        </form>
                                                    }
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="tab-pane fade @(activeTab == "folders" ? "show active" : "")" id="folders" role="tabpanel">
                    <div class="d-flex justify-content-end mb-3">
                        @if (canAdd)
                        {
                            <button type="button" class="btn btn-success fw-bold shadow-sm px-4" data-bs-toggle="modal" data-bs-target="#createFolderModal">
                                <i class="bi bi-folder-plus me-1"></i> Create New Album
                            </button>
                        }
                    </div>

                    <div class="table-responsive">
                        <table id="foldersTable" class="table gov-table align-middle">
                            <thead>
                                <tr>
                                    <th style="width: 100px;">Cover</th>
                                    <th>Album Name</th>
                                    <th>Created Date</th>
                                    <th class="text-center">Status</th>
                                    <th class="text-center" width="180">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (folders != null)
                                {
                                    foreach (var f in folders)
                                    {
                                        <tr>
                                            <td>
                                                @if (!string.IsNullOrEmpty(f.CoverImagePath))
                                                {
                                                    <img src="@f.CoverImagePath" class="img-thumbnail" style="height: 50px; width: 80px; object-fit: cover;" />
                                                }
                                                else
                                                {
                                                    <i class="bi bi-folder-fill text-warning fs-4"></i>
                                                }
                                            </td>
                                            <td class="fw-bold">@f.FolderName</td>
                                            <td>@f.CreatedDate.ToString("dd MMM yyyy")</td>
                                            <td class="text-center">
                                                <span class="@(f.IsActive ? "gov-badge-active" : "gov-badge-inactive")">
                                                    @(f.IsActive ? "Active" : "Inactive")
                                                </span>
                                            </td>
                                            <td class="text-center">
                                                <div class="btn-group shadow-sm">
                                                    @if (canEdit)
                                                    {
                                                        <a asp-action="EditFolder" asp-route-id="@f.Id" class="btn btn-sm btn-outline-primary">
                                                            <i class="bi bi-pencil-square"></i> Edit
                                                        </a>
                                                    }
                                                    @if (canDelete)
                                                    {
                                                        <form asp-action="DeleteFolder" asp-route-id="@f.Id" method="post" onsubmit="return confirm('Delete this Album?');">
                                                            @Html.AntiForgeryToken()
                                                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                                                <i class="bi bi-trash"></i> Delete
                                                            </button>
                                                        </form>
                                                    }
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="imagePreviewModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content shadow-lg border-0">
            <div class="modal-header bg-light">
                <h5 class="modal-title">Image Preview</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center p-3">
                <img id="modalImage" src="" class="img-fluid" style="max-height: 70vh; border-radius: 4px;" />
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="createFolderModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">Create New Album</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="CreateFolder" asp-controller="SiteGallery" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="master-label">Album Name <span class="text-danger">*</span></label>
                        <input name="FolderName" class="master-input" required />
                    </div>
                    <div class="mb-3">
                        <label class="master-label">Cover Image</label>
                        <input name="CoverImageUpload" type="file" class="master-input" accept="image/*" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Close</button>
                    <button type="submit" class="btn btn-primary px-4">Save Album</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script>
        $(document).ready(function () {
            // DataTables
            $('#imagesTable, #foldersTable').DataTable({
                responsive: true,
                dom: '<"d-flex justify-content-between mb-3"f>rt<"d-flex justify-content-between mt-3"ip>',
                language: { search: "Quick Search: " }
            });

            // Image Preview Modal Logic
            $('.img-thumbnail').on('click', function () {
                var imgSrc = $(this).attr('src');
                $('#modalImage').attr('src', imgSrc);
                var previewModal = new bootstrap.Modal(document.getElementById('imagePreviewModal'));
                previewModal.show();
            });
        });
    </script>
}