@model rda_raipur.Models.site.SiteGallery
@{
    ViewData["Title"] = "Upload Gallery Image";
    Layout = "~/Views/AdminShared/_AdminLayout.cshtml";
}

<div class="container-fluid mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">Upload New Gallery Image</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label asp-for="FolderId" class="form-label">Select Album / Folder <span class="text-danger">*</span></label>
                            <select asp-for="FolderId" class="form-control" asp-items="ViewBag.Folders" required>
                                <option value="">-- Select Folder --</option>
                            </select>
                            <span asp-validation-for="FolderId" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Title_en" class="form-label">Title (English)</label>
                                <input asp-for="Title_en" class="form-control" placeholder="Enter English Title" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Title_hi" class="form-label">Title (Hindi)</label>
                                <input asp-for="Title_hi" class="form-control" placeholder="Enter Hindi Title" />
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label">Select Image <span class="text-danger">*</span></label>
                            <input asp-for="ImageUpload" type="file" class="form-control" accept="image/*" required />
                            <small class="text-muted">Recommended size: 800x600 pixels.</small>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a href="@Url.Action("Index")" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Back to List
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-cloud-upload"></i> Upload Image
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>