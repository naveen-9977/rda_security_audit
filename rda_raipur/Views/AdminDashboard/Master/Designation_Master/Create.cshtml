@model rda_raipur.Models.Designation_Master
@{
    ViewData["Title"] = "Add Designation";
    Layout = "~/Views/AdminShared/_AdminLayout.cshtml";
}
<div class="container-fluid mt-4">
    <div class="d-sm-flex align-items-center justify-content-between mb-4 border-bottom pb-3">
        <h1 class="h3 mb-0 text-gray-800">Add Designation</h1>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i> Back</a>
    </div>
    <div class="card shadow-sm border-0 col-lg-8">
        <div class="card-body bg-light">
            <form asp-action="Create" method="post">
                <div class="mb-3">
                    <label class="form-label font-weight-bold">Designation Name (English)</label>
                    <input asp-for="designation_name_en" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label class="form-label font-weight-bold">Designation Name (Hindi)</label>
                    <input asp-for="designation_name_hi" class="form-control" required />
                </div>
                <button type="submit" class="btn btn-success"><i class="bi bi-save"></i> Save Designation</button>
            </form>
        </div>
    </div>
</div>