@model rda_raipur.Models.EmpType_Master

@{
    ViewData["Title"] = "Add Employee Type";
    Layout = "~/Views/AdminShared/_AdminLayout.cshtml";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 text-gray-800">Add Employee Type</h1>
        <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i> Back to List</a>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-body bg-light">
                    <form asp-action="Create" method="post">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="emp_type_name_hi" class="form-label font-weight-bold">Type Name (Hindi) <span class="text-danger">*</span></label>
                                <input asp-for="emp_type_name_hi" class="form-control" required placeholder="हिंदी में नाम दर्ज करें" />
                                <span asp-validation-for="emp_type_name_hi" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="emp_type_name_en" class="form-label font-weight-bold">Type Name (English) <span class="text-danger">*</span></label>
                                <input asp-for="emp_type_name_en" class="form-control" required placeholder="Enter name in English" />
                                <span asp-validation-for="emp_type_name_en" class="text-danger small"></span>
                            </div>

                            <div class="col-md-12 mb-4">
                                <div class="form-check form-switch mt-2">
                                    <input class="form-check-input" type="checkbox" asp-for="IsActive" checked>
                                    <label class="form-check-label font-weight-bold" asp-for="IsActive">Is Active?</label>
                                </div>
                            </div>

                            <div class="col-12 mt-2">
                                <button type="submit" class="btn btn-primary shadow-sm"><i class="bi bi-save me-1"></i> Save Record</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}