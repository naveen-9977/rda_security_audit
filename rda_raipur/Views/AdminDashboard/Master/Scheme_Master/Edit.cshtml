@model rda_raipur.Models.Scheme_Master

@{
    ViewData["Title"] = "Edit Scheme";
    Layout = "~/Views/AdminShared/_AdminLayout.cshtml";
}

<link href="~/css/master-pages.css" rel="stylesheet" />

<div class="master-container">
    <div class="master-page-header">
        <h3 class="master-title"><i class="bi bi-pencil-square text-primary"></i> Edit Scheme</h3>
        <a asp-action="Index" class="btn btn-outline-secondary fw-bold rounded-pill px-4">
            <i class="bi bi-arrow-left"></i> Back to List
        </a>
    </div>

    <div class="card master-card">
        <div class="master-card-body p-4">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger shadow-sm border-0 mb-4"></div>

                <input type="hidden" asp-for="scheme_id" />
                <input type="hidden" asp-for="create_date" />
                <input type="hidden" asp-for="created_by" />

                <div class="row">
                    <div class="col-md-6 form-group-spaced">
                        <label asp-for="scheme_name_en" class="master-label">Scheme Name (English) <span class="text-danger">*</span></label>
                        <input asp-for="scheme_name_en" class="master-input w-100" placeholder="e.g. Kamal Vihar" />
                        <span asp-validation-for="scheme_name_en" class="text-danger small fw-bold"></span>
                    </div>

                    <div class="col-md-6 form-group-spaced">
                        <label asp-for="scheme_name_hi" class="master-label">योजना का नाम (Hindi) <span class="text-danger">*</span></label>
                        <input asp-for="scheme_name_hi" class="master-input w-100" placeholder="उदा. कमल विहार" />
                        <span asp-validation-for="scheme_name_hi" class="text-danger small fw-bold"></span>
                    </div>

                    <div class="col-md-6 form-group-spaced">
                        <label asp-for="scheme_sort_name_en" class="master-label">Short Name (English)</label>
                        <input asp-for="scheme_sort_name_en" class="master-input w-100" placeholder="e.g. KV" />
                        <span asp-validation-for="scheme_sort_name_en" class="text-danger small fw-bold"></span>
                    </div>

                    <div class="col-md-6 form-group-spaced">
                        <label asp-for="scheme_sort_name_hi" class="master-label">संक्षिप्त नाम (Hindi)</label>
                        <input asp-for="scheme_sort_name_hi" class="master-input w-100" placeholder="उदा. क.वि." />
                        <span asp-validation-for="scheme_sort_name_hi" class="text-danger small fw-bold"></span>
                    </div>

                    <div class="col-md-12 form-group-spaced">
                        <label asp-for="scheme_rera_no" class="master-label">RERA Number</label>
                        <input asp-for="scheme_rera_no" class="master-input w-100" placeholder="Enter RERA Registration No" />
                        <span asp-validation-for="scheme_rera_no" class="text-danger small fw-bold"></span>
                    </div>

                    <div class="col-md-6 form-group-spaced">
                        <div class="d-flex gap-4 mt-4 pt-2">
                            <div class="form-check form-switch">
                                <input class="form-check-input fs-4" asp-for="IsActive" id="IsActiveSwitch">
                                <label class="form-check-label fw-bold mt-1 ms-2" for="IsActiveSwitch">Is Active</label>
                            </div>
                            <div class="form-check form-switch">
                                <input class="form-check-input fs-4" asp-for="IsDeleted" id="IsDeletedSwitch">
                                <label class="form-check-label fw-bold mt-1 ms-2" for="IsDeletedSwitch">Is Deleted</label>
                            </div>
                        </div>
                    </div>
                </div>

                <hr class="my-4 border-light">

                <div class="d-flex justify-content-end gap-3">
                    <a asp-action="Index" class="btn btn-light border fw-bold px-4">Cancel</a>
                    <button type="submit" class="btn btn-primary fw-bold px-5 shadow-sm" style="background-color: #003366; border: none;">
                        <i class="bi bi-save me-1"></i> Update Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}