@model rda_raipur.Models.Block_Master

@{
    ViewData["Title"] = "Create Block";
    Layout = "~/Views/AdminShared/_AdminLayout.cshtml";
}

<link href="~/css/master-pages.css" rel="stylesheet" />

<div class="master-container">
    <div class="master-page-header">
        <h3 class="master-title"><i class="bi bi-buildings-fill text-primary"></i> Create New Block</h3>
        <a asp-action="Index" class="btn btn-outline-secondary fw-bold rounded-pill px-4">
            <i class="bi bi-arrow-left"></i> Back to List
        </a>
    </div>

    <div class="card master-card">
        <div class="master-card-body p-4">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger shadow-sm border-0 mb-4"></div>

                <div class="row">
                    <div class="col-md-6 form-group-spaced">
                        <label asp-for="scheme_id" class="master-label">Select Scheme <span class="text-danger">*</span></label>
                        <select id="schemeDropdown" asp-for="scheme_id" class="master-input w-100" asp-items="ViewBag.SchemeList">
                            <option value="">-- Select Scheme --</option>
                        </select>
                        <span asp-validation-for="scheme_id" class="text-danger small fw-bold"></span>
                    </div>

                    <div class="col-md-6 form-group-spaced">
                        <label asp-for="sector_id" class="master-label">Select Sector <span class="text-danger">*</span></label>
                        <select id="sectorDropdown" asp-for="sector_id" class="master-input w-100">
                            <option value="">-- Select Sector --</option>
                        </select>
                        <span asp-validation-for="sector_id" class="text-danger small fw-bold"></span>
                    </div>

                    <div class="col-md-6 form-group-spaced">
                        <label asp-for="block_name_en" class="master-label">Block Name (English) <span class="text-danger">*</span></label>
                        <input asp-for="block_name_en" class="master-input w-100" placeholder="e.g. Block A" />
                        <span asp-validation-for="block_name_en" class="text-danger small fw-bold"></span>
                    </div>

                    <div class="col-md-6 form-group-spaced">
                        <label asp-for="block_name_hi" class="master-label">ब्लॉक का नाम (Hindi)</label>
                        <input asp-for="block_name_hi" class="master-input w-100" placeholder="उदा. ब्लॉक ए" />
                        <span asp-validation-for="block_name_hi" class="text-danger small fw-bold"></span>
                    </div>

                    <div class="col-md-6 form-group-spaced">
                        <div class="d-flex gap-4 mt-3 pt-2">
                            <div class="form-check form-switch">
                                <input class="form-check-input fs-4" asp-for="IsActive" id="IsActiveSwitch" checked>
                                <label class="form-check-label fw-bold mt-1 ms-2" for="IsActiveSwitch">Is Active</label>
                            </div>
                            <div class="form-check form-switch">
                                <input class="form-check-input fs-4" asp-for="IsDeleted" id="IsDeletedSwitch">
                                <label class="form-check-label fw-bold mt-1 ms-2" for="IsDeletedSwitch">Is Deleted</label>
                            </div>
                        </div>
                    </div>
                </div>

                <hr class="my-4 border-light">

                <div class="d-flex justify-content-end gap-3">
                    <a asp-action="Index" class="btn btn-light border fw-bold px-4">Cancel</a>
                    <button type="submit" class="btn btn-primary fw-bold px-5 shadow-sm" style="background-color: #003366; border: none;">
                        <i class="bi bi-save me-1"></i> Save Block
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function () {
            $('#schemeDropdown').change(function () {
                var schemeId = $(this).val();
                var sectorDropdown = $('#sectorDropdown');

                sectorDropdown.empty();
                sectorDropdown.append('<option value="">-- Select Sector --</option>');

                if (schemeId) {
                    $.ajax({
                        url: '@Url.Action("GetSectorsByScheme", "Block_Master")',
                        type: 'GET',
                        data: { schemeId: schemeId },
                        success: function (data) {
                            $.each(data, function (i, sector) {
                                sectorDropdown.append(
                                    '<option value="' + sector.sector_id + '">' + sector.sector_name_en + '</option>'
                                );
                            });
                        }
                    });
                }
            });
        });
    </script>
}