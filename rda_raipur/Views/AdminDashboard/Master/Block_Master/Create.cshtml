@model rda_raipur.Models.Block_Master
@{
    ViewData["Title"] = "Create Block";
    Layout = "~/Views/AdminShared/_AdminLayout.cshtml";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="h3 mb-0 text-gray-800">Add New Block</h2>
        <a asp-action="Index" class="btn btn-outline-secondary shadow-sm">
            <i class="bi bi-arrow-left me-1"></i> Back to List
        </a>
    </div>

    <div class="card shadow border-0 rounded-3 mb-4">
        <div class="card-body p-4">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row">
                  @*   <div class="col-md-6 mb-4">
                        <label asp-for="scheme_id" class="form-label fw-bold">Select Scheme <span class="text-danger">*</span></label>
                        <select asp-for="scheme_id" class="form-select" asp-items="ViewBag.SchemeList">
                            <option value="">-- Select a Scheme --</option>
                        </select>
                        <span asp-validation-for="scheme_id" class="text-danger"></span>
                    </div> *@

                    <div class="col-md-6 mb-4" ">
                        <label>Scheme</label>
                        <select id="schemeDropdown" asp-for="scheme_id" class="form-control">
                            <option value="">Select Scheme</option>
                            @foreach (var item in ViewBag.SchemeList as SelectList)
                            {
                                <option value="@item.Value">@item.Text</option>
                            }
                        </select>
                    </div>


                    <div class="col-md-6 mb-4">
                        @* <label asp-for="sector_id" class="form-label fw-bold">Select Sector <span class="text-danger">*</span></label>
                        <select asp-for="sector_id" class="form-select" asp-items="ViewBag.SectorList">
                            <option value="">-- Select a Sector --</option>
                        </select>
                        <span asp-validation-for="sector_id" class="text-danger"></span> *@

                        <div class="col-md-6 mb-4" ">
                            <label>Sector</label>
                            <select id="sectorDropdown" asp-for="sector_id" class="form-control">
                                <option value="">Select Sector</option>
                            </select>
                        </div>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="block_name_en" class="form-label fw-bold">Block Name (English) <span class="text-danger">*</span></label>
                        <input asp-for="block_name_en" class="form-control" placeholder="e.g., Block A" />
                        <span asp-validation-for="block_name_en" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="block_name_hi" class="form-label fw-bold">Block Name (Hindi)</label>
                        <input asp-for="block_name_hi" class="form-control" placeholder="ब्लॉक ए" />
                        <span asp-validation-for="block_name_hi" class="text-danger"></span>
                    </div>
                </div>

                <div class="border-top pt-3 mt-2">
                    <button type="submit" class="btn btn-success px-4">
                        <i class="bi bi-check-circle me-1"></i> Save Block
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>
    $(document).ready(function () {

    $('#schemeDropdown').change(function () {

    var schemeId = $(this).val();

    $('#sectorDropdown').empty();
    $('#sectorDropdown').append('<option value="">Select Sector</option>');

    if (schemeId) {
    $.ajax({
    url: '/Block_Master/GetSectorsByScheme',
    type: 'GET',
    data: { schemeId: schemeId },
    success: function (data) {

    $.each(data, function (i, sector) {
    $('#sectorDropdown').append(
    '<option value="' + sector.sector_id + '">' + sector.sector_name_en + '</option>'
    );
    });

    }
    });
    }
    });

    });
</script>