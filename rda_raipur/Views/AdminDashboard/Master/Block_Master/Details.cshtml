@model rda_raipur.Models.Block_Master
@{
    ViewData["Title"] = "Block Details";
    Layout = "~/Views/AdminShared/_AdminLayout.cshtml";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="h3 mb-0 text-gray-800">Block Information</h2>
        <div>
            <a asp-action="Edit" asp-route-id="@Model?.block_id" class="btn btn-primary shadow-sm me-2">
                <i class="bi bi-pencil-square me-1"></i> Edit
            </a>
            <a asp-action="Index" class="btn btn-outline-secondary shadow-sm">
                <i class="bi bi-arrow-left me-1"></i> Back to List
            </a>
        </div>
    </div>

    <div class="card shadow border-0 rounded-3 mb-4">
        <div class="card-body p-4">
            <h5 class="card-title border-bottom pb-2 mb-4 text-primary">
                <i class="bi bi-info-circle me-2"></i> Details for @Model.block_name_en
            </h5>

            <dl class="row mb-0">
                <dt class="col-sm-3 text-muted mb-3">Scheme ID</dt>
                <dd class="col-sm-9 fw-bold mb-3 text-primary">@Model.scheme_id</dd>

                <dt class="col-sm-3 text-muted mb-3">Sector ID</dt>
                <dd class="col-sm-9 fw-bold mb-3 text-primary">@Model.sector_id</dd>

                <dt class="col-sm-3 text-muted mb-3">Block Name (EN)</dt>
                <dd class="col-sm-9 fw-bold mb-3">@Model.block_name_en</dd>

                <dt class="col-sm-3 text-muted mb-3">Block Name (HI)</dt>
                <dd class="col-sm-9 mb-3">@Model.block_name_hi</dd>

                <dt class="col-sm-3 text-muted mb-3">Created Date</dt>
                <dd class="col-sm-9 mb-3">@(Model.Create_Date?.ToString("dd MMM yyyy, hh:mm tt") ?? "N/A")</dd>

                <dt class="col-sm-3 text-muted mb-3">Created By</dt>
                <dd class="col-sm-9 mb-3">@Model.created_by</dd>

                <dt class="col-sm-3 text-muted mb-3">Updated Date</dt>
                <dd class="col-sm-9 mb-3">@(Model.updated_Date?.ToString("dd MMM yyyy, hh:mm tt") ?? "N/A")</dd>

                <dt class="col-sm-3 text-muted mb-3">Status</dt>
                <dd class="col-sm-9 mb-3">
                    @if (Model.IsActive)
                    {
                        <span class="badge bg-success">Active</span>
                    }
                    else
                    {

                        <span class="badge bg-danger">Inactive</span>
                    }
                </dd>
            </dl>
        </div>
    </div>
</div>