@model IEnumerable<rda_raipur.Models.site.SitePopup>
@using rda_raipur.Data
@using System.Security.Claims
@using System.Linq
@inject ApplicationDbContext _context

@{
    ViewData["Title"] = "Manage Welcome Popups";
    Layout = "~/Views/AdminShared/_AdminLayout.cshtml";

    // --- Fixed Permission Logic (No 'Include' needed) ---
    var userIdStr = User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
    int userId = int.TryParse(userIdStr, out int uid) ? uid : 0;
    bool isAdmin = User.IsInRole("Admin");

    // Join ka use kiya hai taki 'Include' ki zaroorat na pade
    var permission = (from p in _context.EmployeePermissions
                      join m in _context.AppModules on p.ModuleId equals m.ModuleId
                      where p.UserId == userId && m.ControllerName == "SitePopup"
                      select p).FirstOrDefault();

    bool canAdd = isAdmin || (permission?.CanAdd ?? false);
    bool canEdit = isAdmin || (permission?.CanEdit ?? false);
    bool canDelete = isAdmin || (permission?.CanDelete ?? false);
}

<link href="~/css/master-pages.css" rel="stylesheet" />
<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />

<div class="master-container">
    <div class="master-page-header">
        <h2 class="master-title">
            <i class="bi bi-window-stack text-primary me-2"></i> Manage Welcome Popups
        </h2>
        @if (canAdd)
        {
            <a asp-action="Create" class="btn btn-primary fw-bold shadow-sm px-4" style="background-color: #003366; border: none;">
                <i class="bi bi-plus-circle me-1"></i> Add New Popup
            </a>
        }
    </div>

    <div class="card master-card">
        <div class="card-body p-3">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
                    <i class="bi bi-check-circle me-1"></i> @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <div class="table-responsive">
                <table id="popupTable" class="table gov-table align-middle">
                    <thead>
                        <tr>
                            <th style="width: 80px;">Order</th>
                            <th style="width: 150px;">Preview</th>
                            <th>Title</th>
                            <th class="text-center">Status</th>
                            <th class="text-center" width="180">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null)
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="fw-bold text-center">@item.DisplayOrder</td>
                                    <td>
                                        <img src="@item.ImagePath"
                                             class="img-thumbnail shadow-sm"
                                             style="height: 60px; width: 100px; object-fit: cover; cursor: pointer;"
                                             onerror="this.src='/images/placeholder.png'"
                                             data-bs-toggle="modal"
                                             data-bs-target="#imageModal"
                                             onclick="showImage('@item.ImagePath')" />
                                    </td>
                                    <td class="fw-semibold">@(item.Title ?? "N/A")</td>
                                    <td class="text-center">
                                        <span class="@(item.IsActive ? "gov-badge-active" : "gov-badge-inactive")">
                                            @(item.IsActive ? "Active" : "Inactive")
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group shadow-sm">
                                            @if (canEdit)
                                            {
                                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                                    <i class="bi bi-pencil-square"></i> Edit
                                                </a>
                                            }
                                            @if (canDelete)
                                            {
                                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline;" onsubmit="return confirm('Delete this popup?');">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                                        <i class="bi bi-trash"></i> Delete
                                                    </button>
                                                </form>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="imageModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content shadow-lg">
            <div class="modal-header">
                <h5 class="modal-title">Popup Image Preview</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center p-0">
                <img src="" id="modalImage" class="img-fluid" style="width: 100%;" />
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script>
        function showImage(src) {
            document.getElementById('modalImage').src = src;
        }

        $(document).ready(function () {
            $('#popupTable').DataTable({
                responsive: true,
                dom: '<"d-flex justify-content-between mb-3"f>rt<"d-flex justify-content-between mt-3"ip>',
                language: { search: "Quick Search: " }
            });
        });
    </script>
}