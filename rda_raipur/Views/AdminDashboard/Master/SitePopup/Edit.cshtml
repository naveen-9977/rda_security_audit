@model rda_raipur.Models.site.SitePopup

@{
    ViewData["Title"] = "Edit Welcome Popup";
    Layout = "~/Views/AdminShared/_AdminLayout.cshtml";
}

<div class="container-fluid pt-4 px-4">
    <div class="bg-light rounded p-4">
        <h5 class="mb-4">Edit Welcome Popup</h5>

        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            <input type="hidden" asp-for="Id" />

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Title" class="form-label">Title / Reference Name</label>
                    <input asp-for="Title" class="form-control" required />
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="DisplayOrder" class="form-label">Display Order</label>
                    <input asp-for="DisplayOrder" class="form-control" type="number" />
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="ImageUpload" class="form-label">Upload New Image (Leave blank to keep current)</label>
                    <input asp-for="ImageUpload" class="form-control" type="file" accept="image/*" />

                    @if (!string.IsNullOrEmpty(Model.ImagePath))
                    {
                        <div class="mt-2">
                            <small class="text-muted d-block mb-1">Current Image:</small>
                            <img src="@Model.ImagePath" alt="Current Image" style="height: 100px; border-radius: 5px; border: 1px solid #ccc;" />
                        </div>
                    }
                </div>

                <div class="col-md-6 mb-3">
                    <div class="form-check mt-4">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                        <label asp-for="IsActive" class="form-check-label">Is Active?</label>
                    </div>
                </div>
            </div>

            <button type="submit" class="btn btn-success mt-3">Update Popup</button>
            <a asp-action="Index" class="btn btn-secondary mt-3 ms-2">Cancel</a>
        </form>
    </div>
</div>