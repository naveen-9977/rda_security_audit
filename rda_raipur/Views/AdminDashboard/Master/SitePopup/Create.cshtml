@model rda_raipur.Models.site.SitePopup

@{
    ViewData["Title"] = "Add Welcome Popup";
    Layout = "~/Views/AdminShared/_AdminLayout.cshtml";
}

<div class="container-fluid pt-4 px-4">
    <div class="bg-light rounded p-4">
        <h5 class="mb-4">Add New Welcome Popup</h5>

        <form asp-action="Create" method="post" enctype="multipart/form-data">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Title" class="form-label">Title / Reference Name</label>
                    <input asp-for="Title" class="form-control" required />
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="DisplayOrder" class="form-label">Display Order (eg. 1, 2, 3)</label>
                    <input asp-for="DisplayOrder" class="form-control" type="number" value="1" />
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="ImageUpload" class="form-label">Upload Popup Image (Jpg/Png)</label>
                    <input asp-for="ImageUpload" class="form-control" type="file" accept="image/*" required />
                </div>

                <div class="col-md-6 mb-3 d-flex align-items-end">
                    <div class="form-check">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" checked />
                        <label asp-for="IsActive" class="form-check-label">Is Active?</label>
                    </div>
                </div>
            </div>

            <button type="submit" class="btn btn-success mt-3">Save Popup</button>
            <a asp-action="Index" class="btn btn-secondary mt-3 ms-2">Cancel</a>
        </form>
    </div>
</div>