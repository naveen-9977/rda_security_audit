@model rda_raipur.Models.PropertyModelMaster

@{
    ViewData["Title"] = "Edit Property Details";
    Layout = "~/Views/AdminShared/_AdminLayout.cshtml";
}

<link href="~/css/master-pages.css" rel="stylesheet" />

<div class="master-container">
    <div class="master-page-header">
        <h3 class="master-title text-capitalize"><i class="bi bi-pencil-square text-primary"></i> Edit Property Details</h3>
        <a asp-action="Index" class="btn btn-outline-secondary fw-bold rounded-pill px-4">
            <i class="bi bi-arrow-left"></i> Back to List
        </a>
    </div>

    <div class="card master-card">
        <div class="card-body p-4">
            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="All" class="text-danger fw-bold shadow-sm border-0 mb-4"></div>

                <input type="hidden" asp-for="Property_Id" />

                <div class="row">
                    <div class="col-md-4 form-group-spaced">
                        <label asp-for="scheme_id" class="master-label">Select Scheme <span class="text-danger">*</span></label>
                        <select id="schemeDropdown" asp-for="scheme_id" class="master-input w-100" asp-items="ViewBag.SchemeList">
                            <option value="">-- Select Scheme --</option>
                        </select>
                        <span asp-validation-for="scheme_id" class="text-danger small fw-bold"></span>
                    </div>

                    <div class="col-md-4 form-group-spaced">
                        <label asp-for="sector_id" class="master-label">Select Sector <span class="text-danger">*</span></label>
                        <select id="sectorDropdown" asp-for="sector_id" class="master-input w-100" asp-items="ViewBag.SectorList">
                            <option value="">-- Select Sector --</option>
                        </select>
                        <span asp-validation-for="sector_id" class="text-danger small fw-bold"></span>
                    </div>

                    <div class="col-md-4 form-group-spaced">
                        <label asp-for="block_id" class="master-label">Select Block <span class="text-danger">*</span></label>
                        <select id="blockDropdown" asp-for="block_id" class="master-input w-100" asp-items="ViewBag.BlockList">
                            <option value="">-- Select Block --</option>
                        </select>
                        <span asp-validation-for="block_id" class="text-danger small fw-bold"></span>
                    </div>

                    <div class="col-md-6 form-group-spaced">
                        <label asp-for="Property_Type_Name_en" class="master-label">Property Type (English) <span class="text-danger">*</span></label>
                        <input asp-for="Property_Type_Name_en" class="master-input w-100" required />
                        <span asp-validation-for="Property_Type_Name_en" class="text-danger small fw-bold"></span>
                    </div>

                    <div class="col-md-6 form-group-spaced">
                        <label asp-for="Property_Type_Name_hi" class="master-label">प्रॉपर्टी टाइप (Hindi)</label>
                        <input asp-for="Property_Type_Name_hi" class="master-input w-100" />
                        <span asp-validation-for="Property_Type_Name_hi" class="text-danger small fw-bold"></span>
                    </div>

                    <div class="col-md-6 form-group-spaced mt-2">
                        <label class="master-label d-block mb-2">Status <span class="text-danger">*</span></label>

                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="radio" name="IsActive" id="statusActive" value="true" @(Model.IsActive == true ? "checked" : "") required />
                            <label class="form-check-label fw-bold ms-1" for="statusActive">Active</label>
                        </div>

                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="radio" name="IsActive" id="statusInactive" value="false" @(Model.IsActive == false ? "checked" : "") required />
                            <label class="form-check-label fw-bold ms-1" for="statusInactive">Inactive</label>
                        </div>
                    </div>

                    <div class="col-md-6 form-group-spaced mt-2">
                        <label class="master-label d-block mb-2">Is Deleted <span class="text-danger">*</span></label>

                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="radio" name="IsDeleted" id="deleteTrue" value="true" @(Model.IsDeleted == true ? "checked" : "") required />
                            <label class="form-check-label fw-bold ms-1 text-danger" for="deleteTrue">Yes (Deleted)</label>
                        </div>

                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="radio" name="IsDeleted" id="deleteFalse" value="false" @(Model.IsDeleted == false ? "checked" : "") required />
                            <label class="form-check-label fw-bold ms-1" for="deleteFalse">No</label>
                        </div>
                    </div>
                </div>

                <hr class="my-4 border-light">

                <div class="d-flex justify-content-end gap-3">
                    <a asp-action="Index" class="btn btn-light border fw-bold px-4">Cancel</a>
                    <button type="submit" class="btn btn-primary fw-bold px-5 shadow-sm" style="background-color: #003366; border: none;">
                        <i class="bi bi-save me-1"></i> Update Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function () {
            // Scheme बदलने पर Sector लोड करें
            $('#schemeDropdown').change(function () {
                var schemeId = $(this).val();
                $('#sectorDropdown').empty().append('<option value="">-- Select Sector --</option>');
                $('#blockDropdown').empty().append('<option value="">-- Select Block --</option>');
                if (schemeId) {
                    $.getJSON('@Url.Action("GetSectorsByScheme", "PropertyModelMasters")', { schemeId: schemeId }, function (data) {
                        $.each(data, function (i, item) {
                            $('#sectorDropdown').append('<option value="' + item.sector_id + '">' + item.sector_name_en + '</option>');
                        });
                    });
                }
            });

            // Sector बदलने पर Block लोड करें
            $('#sectorDropdown').change(function () {
                var sectorId = $(this).val();
                $('#blockDropdown').empty().append('<option value="">-- Select Block --</option>');
                if (sectorId) {
                    $.getJSON('@Url.Action("GetBlocksBySector", "PropertyModelMasters")', { sectorId: sectorId }, function (data) {
                        $.each(data, function (i, item) {
                            $('#blockDropdown').append('<option value="' + item.block_id + '">' + item.block_name_en + '</option>');
                        });
                    });
                }
            });
        });
    </script>
}