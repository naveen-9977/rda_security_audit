@model rda_raipur.Models.site.SiteCarousel

@{
    ViewData["Title"] = "Add Carousel Image";
    Layout = "~/Views/AdminShared/_AdminLayout.cshtml";
}

<link href="~/css/master-pages.css" rel="stylesheet" />

<div class="master-container">
    <div class="master-page-header">
        <h3 class="master-title"><i class="bi bi-plus-circle text-primary"></i> Add New Carousel Image</h3>
        <a asp-action="Index" class="btn btn-outline-secondary fw-bold rounded-pill px-4">
            <i class="bi bi-arrow-left"></i> Back to List
        </a>
    </div>

    <div class="card master-card">
        <div class="card-body p-4">
            <form asp-action="Create" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="alert alert-danger shadow-sm border-0 mb-4"></div>

                <div class="row">
                    <div class="col-md-6 form-group-spaced">
                        <label asp-for="Caption_en" class="master-label">Caption (English)</label>
                        <input asp-for="Caption_en" class="master-input" placeholder="English text on slider" />
                        <span asp-validation-for="Caption_en" class="text-danger small fw-bold"></span>
                    </div>

                    <div class="col-md-6 form-group-spaced">
                        <label asp-for="Caption_hi" class="master-label">Caption (Hindi)</label>
                        <input asp-for="Caption_hi" class="master-input" placeholder="Hindi text on slider" />
                        <span asp-validation-for="Caption_hi" class="text-danger small fw-bold"></span>
                    </div>

                    <div class="col-md-8 form-group-spaced">
                        <label asp-for="ImageUpload" class="master-label">Select Image <span class="text-danger">*</span></label>
                        <input asp-for="ImageUpload" type="file" class="master-input p-1" accept="image/*" required />
                        <small class="text-muted d-block mt-1">High resolution recommended (e.g., 1920x800).</small>
                    </div>

                    <div class="col-md-4 form-group-spaced">
                        <label asp-for="DisplayOrder" class="master-label">Display Order</label>
                        <input asp-for="DisplayOrder" type="number" class="master-input" value="1" min="1" />
                        <span asp-validation-for="DisplayOrder" class="text-danger small fw-bold"></span>
                    </div>
                </div>

                <hr class="my-4 border-light">

                <div class="d-flex justify-content-end gap-3">
                    <a asp-action="Index" class="btn btn-light border fw-bold px-4">Cancel</a>
                    <button type="submit" class="btn btn-primary fw-bold px-5 shadow-sm" style="background-color: #003366; border: none;">
                        <i class="bi bi-check-circle me-1"></i> Save Slider Image
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}