@model rda_raipur.Models.site.SiteCarousel

@{
    ViewData["Title"] = "Edit Carousel Slider";
    Layout = "~/Views/AdminShared/_AdminLayout.cshtml";
}

<link href="~/css/master-pages.css" rel="stylesheet" />

<div class="master-container">
    <div class="master-page-header">
        <h3 class="master-title"><i class="bi bi-pencil-square text-primary"></i> Edit Carousel Slider</h3>
        <a asp-action="Index" class="btn btn-outline-secondary fw-bold rounded-pill px-4">
            <i class="bi bi-arrow-left"></i> Back to List
        </a>
    </div>

    <div class="card master-card">
        <div class="card-body p-4">
            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="alert alert-danger shadow-sm border-0 mb-4"></div>

                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="ImagePath" /> <div class="row">
                    <div class="col-md-6 form-group-spaced">
                        <label asp-for="Caption_en" class="master-label">Caption (English)</label>
                        <input asp-for="Caption_en" class="master-input" />
                        <span asp-validation-for="Caption_en" class="text-danger small fw-bold"></span>
                    </div>
                    <div class="col-md-6 form-group-spaced">
                        <label asp-for="Caption_hi" class="master-label">Caption (Hindi)</label>
                        <input asp-for="Caption_hi" class="master-input" />
                        <span asp-validation-for="Caption_hi" class="text-danger small fw-bold"></span>
                    </div>

                    <div class="col-md-6 form-group-spaced">
                        <label asp-for="DisplayOrder" class="master-label">Display Order</label>
                        <input asp-for="DisplayOrder" type="number" class="master-input" />
                        <span asp-validation-for="DisplayOrder" class="text-danger small fw-bold"></span>
                    </div>

                    <div class="col-md-6 form-group-spaced">
                        <label class="master-label">Active Status</label>
                        <div class="form-check form-switch mt-2">
                            <input class="form-check-input fs-4" asp-for="IsActive" id="IsActiveSwitch">
                            <label class="form-check-label fw-bold mt-1 ms-2" for="IsActiveSwitch">Active</label>
                        </div>
                    </div>

                    <div class="col-12 form-group-spaced">
                        <label class="master-label">Current Image</label>
                        <div class="mb-3">
                            <img src="@Model.ImagePath" class="img-thumbnail shadow-sm" style="max-height: 150px;" />
                        </div>
                        <label asp-for="ImageUpload" class="master-label">Change Image (Leave empty to keep current)</label>
                        <input asp-for="ImageUpload" type="file" class="master-input p-1" accept="image/*" />
                    </div>
                </div>

                <hr class="my-4 border-light">

                <div class="d-flex justify-content-end gap-3">
                    <a asp-action="Index" class="btn btn-light border fw-bold px-4">Cancel</a>
                    <button type="submit" class="btn btn-primary fw-bold px-5 shadow-sm" style="background-color: #003366; border: none;">
                        <i class="bi bi-save me-1"></i> Update Slider
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}