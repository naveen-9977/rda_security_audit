@model rda_raipur.Models.site.SiteCarousel
@{
    ViewData["Title"] = "Edit Carousel Slider";
    Layout = "~/Views/AdminShared/_AdminLayout.cshtml";
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card shadow">
                <div class="card-header bg-primary text-white d-flex justify-content-between">
                    <h5 class="mb-0">Edit Carousel Slider</h5>
                    <a asp-action="Index" class="btn btn-light btn-sm">Back to List</a>
                </div>
                <div class="card-body">
                    <form asp-action="Edit" method="post" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <input type="hidden" asp-for="Id" />

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="Caption_en" class="form-label">Caption (English)</label>
                                <input asp-for="Caption_en" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Caption_hi" class="form-label">Caption (Hindi)</label>
                                <input asp-for="Caption_hi" class="form-control" />
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="DisplayOrder" class="form-label">Display Order</label>
                                <input asp-for="DisplayOrder" type="number" class="form-control" />
                            </div>
                            <div class="col-md-6 d-flex align-items-end">
                                <div class="form-check form-switch mb-2">
                                    <input class="form-check-input" type="checkbox" asp-for="IsActive">
                                    <label class="form-check-label" asp-for="IsActive">Is Active</label>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Current Image</label><br />
                            <img src="@Model.ImagePath" class="img-thumbnail mb-2" style="height: 150px;" />
                            <br />
                            <label asp-for="ImageUpload" class="form-label">Change Image (Leave empty to keep current)</label>
                            <input asp-for="ImageUpload" type="file" class="form-control" accept="image/*" />
                        </div>

                        <hr />
                        <button type="submit" class="btn btn-success px-4">Update Slider</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>