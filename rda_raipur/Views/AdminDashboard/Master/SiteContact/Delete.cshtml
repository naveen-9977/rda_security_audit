@model rda_raipur.Models.site.SiteContact

@{
    ViewData["Title"] = "Delete Contact";
    Layout = "~/Views/AdminShared/_AdminLayout.cshtml";
}

<link href="~/css/master-pages.css" rel="stylesheet" />

<div class="master-container">
    <div class="master-page-header">
        <h3 class="master-title text-danger">
            <i class='bx bx-trash'></i> Confirm Delete
        </h3>
        <a asp-action="Index" class="btn btn-outline-secondary fw-bold rounded-pill px-4">
            <i class='bx bx-arrow-back'></i> Back to List
        </a>
    </div>

    <div class="card master-card border-danger shadow-sm">
        <div class="card-header bg-danger text-white p-3">
            <h5 class="mb-0 fw-bold"><i class="bx bx-error-circle"></i> Are you sure you want to delete this contact?</h5>
        </div>
        <div class="card-body p-4">
            <p class="text-muted mb-4">This action is permanent and cannot be undone.</p>

            <div class="row mb-4">
                <div class="col-md-6">
                    <dl class="row">
                        <dt class="col-sm-5 text-muted">Office Name (EN)</dt>
                        <dd class="col-sm-7 fw-bold">@Model.OfficeName</dd>

                        <dt class="col-sm-5 text-muted">Office Name (HI)</dt>
                        <dd class="col-sm-7 fw-bold text-success">@Model.OfficeNameHi</dd>
                    </dl>
                </div>
                <div class="col-md-6">
                    <dl class="row">
                        <dt class="col-sm-5 text-muted">Phone</dt>
                        <dd class="col-sm-7">@Model.Phone1</dd>

                        <dt class="col-sm-5 text-muted">Email</dt>
                        <dd class="col-sm-7">@Model.Email</dd>
                    </dl>
                </div>
            </div>

            <form asp-action="Delete" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-danger px-4 fw-bold">
                        <i class="bx bx-trash"></i> Delete Permanently
                    </button>
                    <a asp-action="Index" class="btn btn-light border px-4 fw-bold">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>