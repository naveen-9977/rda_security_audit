@model rda_raipur.Models.site.SiteContact
@{
    ViewData["Title"] = "Create Contact";
    Layout = "~/Views/AdminShared/_AdminLayout.cshtml";
}

<div class="container-fluid mt-4">
    <div class="card shadow">
        <div class="card-header bg-primary text-white"><h4>Add New Contact Details</h4></div>
        <div class="card-body">
            <form asp-action="Create">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="OfficeName" class="form-label text-primary fw-bold"></label>
                        <input asp-for="OfficeName" class="form-control" placeholder="e.g. Raipur Development Authority" />
                        <span asp-validation-for="OfficeName" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3 bg-light rounded pt-2 pb-2">
                        <label asp-for="OfficeNameHi" class="form-label text-success fw-bold"></label>
                        <input asp-for="OfficeNameHi" class="form-control" placeholder="उदाहरण: रायपुर विकास प्राधिकरण" />
                        <span asp-validation-for="OfficeNameHi" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Address" class="form-label text-primary fw-bold"></label>
                        <textarea asp-for="Address" class="form-control" rows="2"></textarea>
                        <span asp-validation-for="Address" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3 bg-light rounded pt-2 pb-2">
                        <label asp-for="AddressHi" class="form-label text-success fw-bold"></label>
                        <textarea asp-for="AddressHi" class="form-control" rows="2"></textarea>
                        <span asp-validation-for="AddressHi" class="text-danger"></span>
                    </div>

                    <hr class="mt-3 mb-4" />

                    <div class="col-md-4 mb-3">
                        <label asp-for="Phone1" class="form-label"></label>
                        <input asp-for="Phone1" class="form-control" placeholder="Main phone number" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="Phone2" class="form-label"></label>
                        <input asp-for="Phone2" class="form-control" placeholder="Alternate phone" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" class="form-control" type="email" placeholder="Email address" />
                    </div>

                    <div class="col-md-12 mb-3">
                        <label asp-for="MapEmbedUrl" class="form-label">Google Maps Embed URL (Only put the link from the 'src' attribute)</label>
                        <input asp-for="MapEmbedUrl" class="form-control" placeholder="https://www.google.com/maps/embed?pb=..." />
                    </div>

                    <div class="col-md-12 mb-3 form-check ms-3">
                        <input asp-for="IsActive" class="form-check-input" />
                        <label class="form-check-label fw-bold" asp-for="IsActive">Set as Active Contact on Website (This will deactivate others)</label>
                    </div>
                </div>
                <div class="mt-3">
                    <button type="submit" class="btn btn-success px-5"><i class="bx bx-save"></i> Save</button>
                    <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}