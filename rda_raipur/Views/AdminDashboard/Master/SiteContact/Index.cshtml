@model IEnumerable<rda_raipur.Models.site.SiteContact>
@using rda_raipur.Data
@using System.Security.Claims
@inject ApplicationDbContext _context

@{
    ViewData["Title"] = "Manage Site Contacts";
    Layout = "~/Views/AdminShared/_AdminLayout.cshtml";

    // ==========================================
    // PERMISSION LOGIC FOR UI BUTTONS
    // ==========================================
    var userIdStr = User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
    int userId = 0;
    int.TryParse(userIdStr, out userId);

    bool isAdmin = User.IsInRole("Admin");

    // Default permissions
    bool canAdd = isAdmin;
    bool canEdit = isAdmin;
    bool canDelete = isAdmin;

    // Agar Admin nahi hai, toh DB se check karein
    if (!isAdmin && userId > 0)
    {
        var permission = (from p in _context.EmployeePermissions
                          join m in _context.AppModules on p.ModuleId equals m.ModuleId
                          where p.UserId == userId && m.ControllerName == "SiteContact"
                          select p).FirstOrDefault();

        if (permission != null)
        {
            canAdd = permission.CanAdd;
            canEdit = permission.CanEdit;
            canDelete = permission.CanDelete;
        }
    }
}

<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />

<div class="container-fluid mt-4">
    <div class="card shadow">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0"><i class="bx bxs-contact me-2"></i>Manage Contact Details</h5>

            @if (canAdd)
            {
                <a asp-action="Create" class="btn btn-light btn-sm text-primary fw-bold">
                    <i class="bx bx-plus"></i> Add New Contact
                </a>
            }
        </div>
        <div class="card-body">

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bx bx-check-circle me-1"></i> @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <div class="alert alert-info mt-2">
                <i class="bx bx-info-circle me-1"></i> <strong>Note:</strong> Only 1 contact detail can be "Active" at a time for the website.
            </div>

            <div class="table-responsive mt-3">
                <table id="contactTable" class="table table-bordered table-striped table-hover align-middle text-center">
                    <thead class="table-dark">
                        <tr>
                            <th style="width: 50px;">S.No.</th>
                            <th>Office Name (EN / HI)</th>
                            <th>Phone & Email</th>
                            <th>Address (EN / HI)</th>
                            <th>Status</th>
                            <th style="width: 120px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            int count = 1;
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="fw-bold">@count</td>

                                    <td class="text-start">
                                        <strong>@item.OfficeName</strong><br />
                                        <small class="text-success">@item.OfficeNameHi</small>
                                    </td>

                                    <td class="text-start">
                                        <i class="bx bx-phone text-primary"></i> @item.Phone1 <br />
                                        <i class="bx bx-envelope text-danger"></i> @item.Email
                                    </td>

                                    <td class="text-start">
                                        @item.Address<br />
                                        <small class="text-success">@item.AddressHi</small>
                                    </td>

                                    <td>
                                        @if (item.IsActive)
                                        {
                                            <span class="badge bg-success">Active Website Contact</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Inactive</span>
                                        }
                                    </td>

                                    <td>
                                        <div class="d-flex justify-content-center gap-2">
                                            @if (canEdit)
                                            {
                                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning" title="Edit">
                                                    <i class="bx bx-edit"></i>
                                                </a>
                                            }

                                            @if (canDelete)
                                            {
                                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this contact detail?');">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                                                        <i class="bx bx-trash"></i>
                                                    </button>
                                                </form>
                                            }

                                            @if (!canEdit && !canDelete)
                                            {
                                                <span class="text-muted small">No Access</span>
                                            }
                                        </div>
                                    </td>
                                </tr>
                                count++;
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

    <script>
        $(document).ready(function() {
            $('#contactTable').DataTable({
                "pageLength": 10,
                "ordering": true,
                "info": true,
                "language": {
                    "search": "Quick Search: ",
                    "lengthMenu": "Show _MENU_ Contacts"
                }
            });
        });
    </script>
}