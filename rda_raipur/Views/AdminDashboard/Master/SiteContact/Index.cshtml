@model IEnumerable<rda_raipur.Models.site.SiteContact>
@using rda_raipur.Data
@using System.Security.Claims
@inject ApplicationDbContext _context

@{
    ViewData["Title"] = "Manage Site Contacts";
    Layout = "~/Views/AdminShared/_AdminLayout.cshtml";

    // ==========================================
    // PERMISSION LOGIC FOR UI BUTTONS
    // ==========================================
    var userIdStr = User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
    int userId = 0;
    int.TryParse(userIdStr, out userId);

    bool isAdmin = User.IsInRole("Admin");
    bool canAdd = isAdmin;
    bool canEdit = isAdmin;
    bool canDelete = isAdmin;

    if (!isAdmin && userId > 0)
    {
        var permission = (from p in _context.EmployeePermissions
                          join m in _context.AppModules on p.ModuleId equals m.ModuleId
                          where p.UserId == userId && m.ControllerName == "SiteContact"
                          select p).FirstOrDefault();

        if (permission != null)
        {
            canAdd = permission.CanAdd;
            canEdit = permission.CanEdit;
            canDelete = permission.CanDelete;
        }
    }
}

<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />
<link href="~/css/master-pages.css" rel="stylesheet" />

<div class="master-container">
    <div class="master-page-header">
        <h3 class="master-title">
            <i class='bx bxs-contact text-primary'></i> Manage Contact Details
        </h3>

        @if (canAdd)
        {
            <a asp-action="Create" class="btn btn-primary fw-bold shadow-sm px-4" style="background-color: #003366; border: none;">
                <i class="bx bx-plus me-1"></i> Add New Contact
            </a>
        }
    </div>

    <div class="card master-card">
        <div class="card-body p-3">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
                    <i class="bx bx-check-circle me-1"></i> @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <div class="alert alert-info border-0 shadow-sm mb-4">
                <i class="bx bx-info-circle me-1"></i> <strong>Note:</strong> Only 1 contact detail can be "Active" at a time for the website.
            </div>

            <div class="table-responsive">
                <table id="contactTable" class="table gov-table align-middle text-nowrap">
                    <thead>
                        <tr>
                            <th style="width: 50px;">S.No.</th>
                            <th>Office Name (EN / HI)</th>
                            <th>Phone & Email</th>
                            <th>Address (EN / HI)</th>
                            <th class="text-center">Status</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            int count = 1;
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="fw-bold text-center">@count</td>
                                    <td class="text-start">
                                        <div class="fw-bold text-dark">@item.OfficeName</div>
                                        <div class="text-success small">@item.OfficeNameHi</div>
                                    </td>
                                    <td class="text-start">
                                        <div class="d-block"><i class="bx bx-phone text-primary"></i> @item.Phone1</div>
                                        <div class="d-block"><i class="bx bx-envelope text-danger"></i> @item.Email</div>
                                    </td>
                                    <td class="text-start">
                                        <div class="text-wrap" style="max-width: 250px;">@item.Address</div>
                                        <div class="text-success small text-wrap">@item.AddressHi</div>
                                    </td>
                                    <td class="text-center">
                                        <span class="@(item.IsActive ? "gov-badge-active" : "gov-badge-inactive")">
                                            @(item.IsActive ? "Active" : "Inactive")
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group shadow-sm">
                                            @if (canEdit)
                                            {
                                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                                    <i class="bx bx-edit"></i> Edit
                                                </a>
                                            }
                                            @if (canDelete)
                                            {
                                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Are you sure?');">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                                        <i class="bx bx-trash"></i> Delete
                                                    </button>
                                                </form>
                                            }
                                        </div>
                                    </td>
                                </tr>
                                count++;
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script>
        $(document).ready(function() {
            $('#contactTable').DataTable({
                "pageLength": 10,
                "ordering": true,
                "language": { "search": "Quick Search: " }
            });
        });
    </script>
}