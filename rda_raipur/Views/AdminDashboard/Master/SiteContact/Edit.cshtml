@model rda_raipur.Models.site.SiteContact

@{
    ViewData["Title"] = "Edit Contact Details";
    Layout = "~/Views/AdminShared/_AdminLayout.cshtml";
}

<link href="~/css/master-pages.css" rel="stylesheet" />

<div class="master-container">
    <div class="master-page-header">
        <h3 class="master-title"><i class='bx bx-edit text-primary'></i> Edit Contact Details</h3>
        <a asp-action="Index" class="btn btn-outline-secondary fw-bold rounded-pill px-4">
            <i class='bx bx-arrow-back'></i> Back to List
        </a>
    </div>

    <div class="card master-card">
        <div class="card-body p-4">
            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="CreatedDate" />

                <div asp-validation-summary="ModelOnly" class="alert alert-danger shadow-sm border-0 mb-4"></div>

                <div class="row">
                    <div class="col-md-6 form-group-spaced">
                        <label asp-for="OfficeName" class="master-label">Office Name (English) <span class="text-danger">*</span></label>
                        <input asp-for="OfficeName" class="master-input" placeholder="e.g. Raipur Development Authority" required />
                        <span asp-validation-for="OfficeName" class="text-danger small fw-bold"></span>
                    </div>

                    <div class="col-md-6 form-group-spaced">
                        <label asp-for="OfficeNameHi" class="master-label">Office Name (Hindi) <span class="text-danger">*</span></label>
                        <input asp-for="OfficeNameHi" class="master-input" placeholder="उदाहरण: रायपुर विकास प्राधिकरण" required />
                        <span asp-validation-for="OfficeNameHi" class="text-danger small fw-bold"></span>
                    </div>

                    <div class="col-md-6 form-group-spaced">
                        <label asp-for="Address" class="master-label">Address (English) <span class="text-danger">*</span></label>
                        <textarea asp-for="Address" class="master-input" rows="2" required></textarea>
                        <span asp-validation-for="Address" class="text-danger small fw-bold"></span>
                    </div>

                    <div class="col-md-6 form-group-spaced">
                        <label asp-for="AddressHi" class="master-label">Address (Hindi) <span class="text-danger">*</span></label>
                        <textarea asp-for="AddressHi" class="master-input" rows="2" required></textarea>
                        <span asp-validation-for="AddressHi" class="text-danger small fw-bold"></span>
                    </div>

                    <hr class="my-4 border-light">

                    <div class="col-md-4 form-group-spaced">
                        <label asp-for="Phone1" class="master-label">Main Phone</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0"><i class='bx bx-phone'></i></span>
                            <input asp-for="Phone1" class="master-input border-start-0" />
                        </div>
                    </div>

                    <div class="col-md-4 form-group-spaced">
                        <label asp-for="Phone2" class="master-label">Alternate Phone</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0"><i class='bx bx-mobile'></i></span>
                            <input asp-for="Phone2" class="master-input border-start-0" />
                        </div>
                    </div>

                    <div class="col-md-4 form-group-spaced">
                        <label asp-for="Email" class="master-label">Email Address</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0"><i class='bx bx-envelope'></i></span>
                            <input asp-for="Email" class="master-input border-start-0" type="email" />
                        </div>
                    </div>

                    <div class="col-12 form-group-spaced">
                        <label asp-for="MapEmbedUrl" class="master-label">Google Maps Embed URL</label>
                        <input asp-for="MapEmbedUrl" class="master-input" placeholder="Paste link from the 'src' attribute of the embed code" />
                    </div>

                    <div class="col-12 form-group-spaced mt-3">
                        <div class="form-check form-switch">
                            <input asp-for="IsActive" class="form-check-input fs-4" type="checkbox" id="flexSwitchCheckChecked" />
                            <label asp-for="IsActive" class="form-check-label fw-bold mt-1 ms-2" for="flexSwitchCheckChecked">
                                Set as Active Contact on Website (This will deactivate others)
                            </label>
                        </div>
                    </div>
                </div>

                <hr class="my-4 border-light">

                <div class="d-flex justify-content-end gap-3">
                    <a asp-action="Index" class="btn btn-light border fw-bold px-4">Cancel</a>
                    <button type="submit" class="btn btn-primary fw-bold px-5 shadow-sm" style="background-color: #003366; border: none;">
                        <i class='bx bx-check-circle me-1'></i> Update Contact
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}