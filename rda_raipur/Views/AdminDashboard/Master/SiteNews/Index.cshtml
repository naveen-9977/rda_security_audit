@model IEnumerable<rda_raipur.Models.site.SiteNews>
@using rda_raipur.Data
@using System.Security.Claims
@inject ApplicationDbContext _context

@{
    ViewData["Title"] = "News Master";
    Layout = "~/Views/AdminShared/_AdminLayout.cshtml";

    // ==========================================
    // PERMISSION LOGIC FOR UI BUTTONS
    // ==========================================
    var userIdStr = User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
    int userId = 0;
    int.TryParse(userIdStr, out userId);

    bool isAdmin = User.IsInRole("Admin");

    // Default permissions
    bool canAdd = isAdmin;
    bool canEdit = isAdmin;
    bool canDelete = isAdmin;

    // Agar Admin nahi hai, toh DB se check karein
    if (!isAdmin && userId > 0)
    {
        var permission = (from p in _context.EmployeePermissions
                          join m in _context.AppModules on p.ModuleId equals m.ModuleId
                          where p.UserId == userId && m.ControllerName == "SiteNews"
                          select p).FirstOrDefault();

        if (permission != null)
        {
            canAdd = permission.CanAdd;
            canEdit = permission.CanEdit;
            canDelete = permission.CanDelete;
        }
    }
}

<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" />

<div class="container-fluid mt-4">
    <div class="card shadow">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0"><i class="fas fa-newspaper me-2"></i>Manage News / Marquee</h5>

            @if (canAdd)
            {
                <a asp-action="Create" class="btn btn-light btn-sm text-primary fw-bold">
                    <i class="fas fa-plus"></i> Add New News
                </a>
            }
        </div>
        <div class="card-body">

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="fas fa-check-circle me-1"></i> @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <div class="table-responsive mt-3">
                <table id="siteNewsTable" class="table table-bordered table-hover align-middle text-center">
                    <thead class="table-dark">
                        <tr>
                            <th>S.No.</th>
                            <th>News (English)</th>
                            <th>News (Hindi)</th>
                            <th>Target / Attachment</th>
                            <th style="width: 150px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            int count = 1;
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="fw-bold">@count</td>
                                    <td class="text-start">@item.NewsText_en</td>
                                    <td class="text-start">@item.NewsText_hi</td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(item.PdfFilePath))
                                        {
                                            <a href="@item.PdfFilePath" target="_blank" class="badge bg-danger text-white text-decoration-none p-2">
                                                <i class="fas fa-file-pdf"></i> PDF Attached
                                            </a>
                                        }
                                        else if (!string.IsNullOrEmpty(item.LinkUrl))
                                        {
                                            <a href="@item.LinkUrl" target="_blank" class="text-truncate d-inline-block" style="max-width: 150px;">
                                                <i class="fas fa-link"></i> @item.LinkUrl
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">None</span>
                                        }
                                    </td>
                                    <td>
                                        @if (canEdit)
                                        {
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm" title="Edit">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                        }

                                        @if (canDelete)
                                        {
                                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this news?');">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-danger btn-sm" title="Delete">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </form>
                                        }

                                        @if (!canEdit && !canDelete)
                                        {
                                            <span class="text-muted small">No Access</span>
                                        }
                                    </td>
                                </tr>
                                count++;
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

    <script>
        $(document).ready(function() {
            $('#siteNewsTable').DataTable({
                "pageLength": 10,
                "ordering": true,
                "info": true,
                "language": {
                    "search": "Quick Search: ",
                    "lengthMenu": "Show _MENU_ Entries"
                }
            });
        });
    </script>
}