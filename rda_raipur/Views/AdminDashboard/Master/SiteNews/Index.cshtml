@model IEnumerable<rda_raipur.Models.site.SiteNews>
@using rda_raipur.Data
@using System.Security.Claims
@inject ApplicationDbContext _context

@{
    ViewData["Title"] = "News Master";
    Layout = "~/Views/AdminShared/_AdminLayout.cshtml";

    // Permission Logic
    var userIdStr = User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
    int userId = 0;
    int.TryParse(userIdStr, out userId);
    bool isAdmin = User.IsInRole("Admin");

    bool canAdd = isAdmin;
    bool canEdit = isAdmin;
    bool canDelete = isAdmin;

    if (!isAdmin && userId > 0)
    {
        var permission = (from p in _context.EmployeePermissions
                          join m in _context.AppModules on p.ModuleId equals m.ModuleId
                          where p.UserId == userId && m.ControllerName == "SiteNews"
                          select p).FirstOrDefault();

        if (permission != null)
        {
            canAdd = permission.CanAdd;
            canEdit = permission.CanEdit;
            canDelete = permission.CanDelete;
        }
    }
}

<link href="~/css/master-pages.css" rel="stylesheet" />
<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />

<div class="master-container">
    <div class="master-page-header">
        <h2 class="master-title">
            <i class="fas fa-newspaper text-primary me-2"></i> Manage News / Marquee
        </h2>
        @if (canAdd)
        {
            <a asp-action="Create" class="btn btn-primary fw-bold px-4 shadow-sm" style="background-color: #003366; border: none;">
                <i class="fas fa-plus me-1"></i> Add New News
            </a>
        }
    </div>

    <div class="card master-card">
        <div class="card-body p-3">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
                    <i class="fas fa-check-circle me-1"></i> @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <div class="table-responsive">
                <table id="siteNewsTable" class="table gov-table align-middle">
                    <thead>
                        <tr>
                            <th style="width: 50px;">S.No.</th>
                            <th>News (English)</th>
                            <th>News (Hindi)</th>
                            <th>Attachment / Link</th>
                            <th width="160" class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            int count = 1;
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="fw-bold">@count</td>
                                    <td class="text-start fw-semibold">@item.NewsText_en</td>
                                    <td class="text-start">@item.NewsText_hi</td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(item.PdfFilePath))
                                        {
                                            <a href="@item.PdfFilePath" target="_blank" class="badge bg-danger text-white text-decoration-none p-2">
                                                <i class="fas fa-file-pdf me-1"></i> PDF Attached
                                            </a>
                                        }
                                        else if (!string.IsNullOrEmpty(item.LinkUrl))
                                        {
                                            <a href="@item.LinkUrl" target="_blank" class="text-primary text-decoration-none">
                                                <i class="fas fa-link me-1"></i> View Link
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">None</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group shadow-sm">
                                            @if (canEdit)
                                            {
                                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary" title="Edit">
                                                    <i class="fas fa-edit me-1"></i> Edit
                                                </a>
                                            }
                                            @if (canDelete)
                                            {
                                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this news?');">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                                                        <i class="fas fa-trash me-1"></i> Delete
                                                    </button>
                                                </form>
                                            }
                                        </div>
                                    </td>
                                </tr>
                                count++;
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

    <script>
        $(document).ready(function() {
            $('#siteNewsTable').DataTable({
                responsive: true,
                pageLength: 10,
                dom: '<"d-flex justify-content-between align-items-center mb-3"f>rt<"d-flex justify-content-between mt-3"ip>',
                language: {
                    search: "Quick Search: ",
                }
            });
        });
    </script>
}