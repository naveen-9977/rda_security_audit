@model IEnumerable<rda_raipur.Models.site.SiteScheme>

@{
    ViewData["Title"] = "Manage RDA Schemes";
    Layout = "~/Views/AdminShared/_AdminLayout.cshtml";
}

<div class="container-fluid p-0">
    <div class="row mb-3">
        <div class="col-12 d-flex justify-content-between align-items-center">
            <h3 class="mb-0 text-primary fw-bold"><i class='bx bx-building-house'></i> Manage RDA Schemes</h3>

            @if (ViewBag.CanAdd == true || User.IsInRole("Admin"))
            {
                <a asp-action="Create" class="btn btn-success fw-bold shadow-sm">
                    <i class='bx bx-plus-circle'></i> Add New Scheme
                </a>
            }
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class='bx bx-check-circle me-1'></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered table-hover align-middle text-nowrap">
                    <thead class="table-light">
                        <tr>
                            <th>S.No</th>
                            <th>Image</th>
                            <th>Scheme Name</th>
                            <th>Location</th>
                            <th>Status</th>
                            <th>Added By</th>
                            <th>Last Updated</th>

                            @if (User.IsInRole("Admin") || ViewBag.CanEdit == true || ViewBag.CanDelete == true)
                            {
                                <th class="text-center">Actions</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            int count = 1;
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td>@count</td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(item.ImagePath))
                                        {
                                            <img src="@item.ImagePath" alt="Scheme" style="width: 60px; height: 40px; object-fit: cover; border-radius: 4px;" />
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">No Image</span>
                                        }
                                    </td>
                                    <td class="fw-bold">@item.SchemeName</td>
                                    <td>@item.Location</td>
                                    <td>
                                        @if (item.IsActive)
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Inactive</span>
                                        }
                                    </td>

                                    <td>
                                        <div class="d-flex flex-column">
                                            <span class="fw-semibold">@(string.IsNullOrEmpty(item.CreatedBy) ? "N/A" : item.CreatedBy)</span>
                                            <small class="text-muted">@item.CreatedDate.ToString("dd MMM yyyy, hh:mm tt")</small>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="d-flex flex-column">
                                            <span class="fw-semibold">@(string.IsNullOrEmpty(item.UpdatedBy) ? "Not Updated" : item.UpdatedBy)</span>
                                            <small class="text-muted">@(item.UpdatedDate.HasValue? item.UpdatedDate.Value.ToString("dd MMM yyyy, hh:mm tt") : "-")</small>
                                        </div>
                                    </td>

                                    @if (User.IsInRole("Admin") || ViewBag.CanEdit == true || ViewBag.CanDelete == true)
                                    {
                                        <td class="text-center">
                                            @if (ViewBag.CanEdit == true || User.IsInRole("Admin"))
                                            {
                                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary" title="Edit">
                                                    <i class='bx bx-edit-alt'></i>
                                                </a>
                                            }

                                            @if (ViewBag.CanDelete == true || User.IsInRole("Admin"))
                                            {
                                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this scheme?');">
                                                    <button type="submit" class="btn btn-sm btn-danger" title="Delete">
                                                        <i class='bx bx-trash'></i>
                                                    </button>
                                                </form>
                                            }
                                        </td>
                                    }
                                </tr>
                                count++;
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center text-muted py-4">
                                    No schemes added yet.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>