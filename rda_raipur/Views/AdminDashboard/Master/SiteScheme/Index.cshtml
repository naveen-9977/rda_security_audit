@model IEnumerable<rda_raipur.Models.site.SiteScheme>

@{
    ViewData["Title"] = "Manage RDA Schemes";
    Layout = "~/Views/AdminShared/_AdminLayout.cshtml";
}

<link href="~/css/master-pages.css" rel="stylesheet" />

<div class="master-container">
    <div class="master-page-header">
        <h3 class="master-title">
            <i class='bx bx-building-house text-primary'></i> Manage RDA Schemes
        </h3>

        @if (ViewBag.CanAdd == true || User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn btn-primary fw-bold shadow-sm px-4" style="background-color: #003366; border: none;">
                <i class='bx bx-plus-circle me-1'></i> Add New Scheme
            </a>
        }
    </div>

    <div class="card master-card">
        <div class="card-body p-3">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
                    <i class='bx bx-check-circle me-1'></i> @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <div class="table-responsive">
                <table class="table gov-table align-middle text-nowrap">
                    <thead>
                        <tr>
                            <th style="width: 60px;">S.No</th>
                            <th>Image</th>
                            <th>Scheme Name</th>
                            <th>Location</th>
                            <th class="text-center">Status</th>
                            <th>Added By</th>
                            <th>Last Updated</th>
                            @if (User.IsInRole("Admin") || ViewBag.CanEdit == true || ViewBag.CanDelete == true)
                            {
                                <th class="text-center">Actions</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            int count = 1;
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="fw-bold text-center">@count</td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(item.ImagePath))
                                        {
                                            <img src="@item.ImagePath" class="img-thumbnail shadow-sm" style="width: 60px; height: 40px; object-fit: cover;" />
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">No Image</span>
                                        }
                                    </td>
                                    <td class="fw-bold">@item.SchemeName</td>
                                    <td>@item.Location</td>
                                    <td class="text-center">
                                        <span class="@(item.IsActive ? "gov-badge-active" : "gov-badge-inactive")">
                                            @(item.IsActive ? "Active" : "Inactive")
                                        </span>
                                    </td>
                                    <td>
                                        <div class="d-flex flex-column">
                                            <span class="fw-semibold">@(string.IsNullOrEmpty(item.CreatedBy) ? "N/A" : item.CreatedBy)</span>
                                            <small class="text-muted">@item.CreatedDate.ToString("dd MMM yyyy")</small>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="d-flex flex-column">
                                            <span class="fw-semibold">@(string.IsNullOrEmpty(item.UpdatedBy) ? "-" : item.UpdatedBy)</span>
                                            <small class="text-muted">@(item.UpdatedDate.HasValue? item.UpdatedDate.Value.ToString("dd MMM yyyy") : "-")</small>
                                        </div>
                                    </td>

                                    @if (User.IsInRole("Admin") || ViewBag.CanEdit == true || ViewBag.CanDelete == true)
                                    {
                                        <td class="text-center">
                                            <div class="btn-group shadow-sm">
                                                @if (ViewBag.CanEdit == true || User.IsInRole("Admin"))
                                                {
                                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                                        <i class='bx bx-edit'></i> Edit
                                                    </a>
                                                }
                                                @if (ViewBag.CanDelete == true || User.IsInRole("Admin"))
                                                {
                                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Are you sure?');">
                                                        @Html.AntiForgeryToken()
                                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                                            <i class='bx bx-trash'></i> Delete
                                                        </button>
                                                    </form>
                                                }
                                            </div>
                                        </td>
                                    }
                                </tr>
                                count++;
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center text-muted py-4">No schemes added yet.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>