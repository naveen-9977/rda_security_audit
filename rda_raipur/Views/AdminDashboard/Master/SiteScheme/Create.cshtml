@model rda_raipur.Models.site.SiteScheme

@{
    ViewData["Title"] = "Add New Scheme";
    Layout = "~/Views/AdminShared/_AdminLayout.cshtml";
}

<div class="container-fluid p-0">
    <div class="row mb-3">
        <div class="col-12">
            <h3 class="mb-0 text-primary fw-bold"><i class='bx bx-plus-circle'></i> Add New Scheme</h3>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            <form asp-action="Create" method="post" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="SchemeName" class="form-label fw-bold">Scheme Name <span class="text-danger">*</span></label>
                        <input asp-for="SchemeName" class="form-control" placeholder="Enter scheme name" required />
                        <span asp-validation-for="SchemeName" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold">Scheme Image (Upload)</label>
                        <input type="file" name="ImageFile" class="form-control" accept="image/*" />
                        <small class="text-muted">Recommended: JPG, PNG</small>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Location" class="form-label fw-bold">Location</label>
                        <input asp-for="Location" class="form-control" placeholder="e.g. Kamal Vihar, Raipur" />
                    </div>

                    <div class="col-md-6">
                        <label asp-for="MapLocationUrl" class="form-label fw-bold">Google Maps Embed URL</label>
                        <input asp-for="MapLocationUrl" class="form-control" placeholder="Paste embed link here" />
                    </div>

                    <div class="col-md-12 mt-3">
                        <div class="form-check">
                            <input asp-for="IsActive" class="form-check-input" type="checkbox" checked="checked" value="true" />
                            <label asp-for="IsActive" class="form-check-label fw-bold text-success">Is Active (Show to public?)</label>
                        </div>
                    </div>

                    <div class="col-12 mt-4 text-end">
                        <a asp-action="Index" class="btn btn-secondary px-4 me-2">Cancel</a>
                        <button type="submit" class="btn btn-success px-5 fw-bold">Save Scheme</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}