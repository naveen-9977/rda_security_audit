@model rda_raipur.Models.site.SiteScheme

@{
    ViewData["Title"] = "Edit Scheme";
    Layout = "~/Views/AdminShared/_AdminLayout.cshtml";
}

<div class="container-fluid p-0">
    <div class="row mb-3">
        <div class="col-12">
            <h3 class="mb-0 text-primary fw-bold"><i class='bx bx-edit'></i> Edit Scheme</h3>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="ImagePath" />
                <input type="hidden" asp-for="CreatedDate" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="SchemeName" class="form-label fw-bold">Scheme Name <span class="text-danger">*</span></label>
                        <input asp-for="SchemeName" class="form-control" required />
                        <span asp-validation-for="SchemeName" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold">Change Image (Leave blank to keep current)</label>
                        <input type="file" name="ImageFile" class="form-control" accept="image/*" />

                        @if (!string.IsNullOrEmpty(Model.ImagePath))
                        {
                            <div class="mt-2">
                                <small class="text-muted d-block">Current Image:</small>
                                <img src="@Model.ImagePath" alt="Current" style="max-height: 60px; border-radius: 4px; border: 1px solid #ddd;" />
                            </div>
                        }
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Location" class="form-label fw-bold">Location</label>
                        <input asp-for="Location" class="form-control" />
                    </div>

                    <div class="col-md-6">
                        <label asp-for="MapLocationUrl" class="form-label fw-bold">Google Maps Embed URL</label>
                        <input asp-for="MapLocationUrl" class="form-control" />
                    </div>

                    <div class="col-md-12 mt-3">
                        <div class="form-check">
                            <input asp-for="IsActive" class="form-check-input" type="checkbox" value="true" />
                            <label asp-for="IsActive" class="form-check-label fw-bold">Is Active (Visible to public)</label>
                        </div>
                    </div>

                    <div class="col-12 mt-4 text-end">
                        <a asp-action="Index" class="btn btn-secondary px-4 me-2">Cancel</a>
                        <button type="submit" class="btn btn-primary px-5 fw-bold">Update Scheme</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}