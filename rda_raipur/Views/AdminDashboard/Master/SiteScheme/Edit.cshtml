@model rda_raipur.Models.site.SiteScheme

@{
    ViewData["Title"] = "Edit Scheme";
    Layout = "~/Views/AdminShared/_AdminLayout.cshtml";
}

<link href="~/css/master-pages.css" rel="stylesheet" />

<div class="master-container">
    <div class="master-page-header">
        <h3 class="master-title"><i class='bx bx-edit text-primary'></i> Edit Scheme</h3>
        <a asp-action="Index" class="btn btn-outline-secondary fw-bold rounded-pill px-4">
            <i class='bx bx-arrow-back'></i> Back to List
        </a>
    </div>

    <div class="card master-card">
        <div class="card-body p-4">
            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="ImagePath" />
                <input type="hidden" asp-for="CreatedDate" />

                <div asp-validation-summary="ModelOnly" class="alert alert-danger shadow-sm border-0 mb-4"></div>

                <div class="row">
                    <div class="col-md-6 form-group-spaced">
                        <label asp-for="SchemeName" class="master-label">Scheme Name <span class="text-danger">*</span></label>
                        <input asp-for="SchemeName" class="master-input" required />
                        <span asp-validation-for="SchemeName" class="text-danger small fw-bold"></span>
                    </div>

                    <div class="col-md-6 form-group-spaced">
                        <label class="master-label">Change Image (Leave blank to keep current)</label>
                        <input type="file" name="ImageFile" class="master-input p-1" accept="image/*" />

                        @if (!string.IsNullOrEmpty(Model.ImagePath))
                        {
                            <div class="mt-2">
                                <small class="text-muted d-block mb-1">Current Image:</small>
                                <img src="@Model.ImagePath" class="img-thumbnail shadow-sm" style="max-height: 80px; border-radius: 5px;" />
                            </div>
                        }
                    </div>

                    <div class="col-md-6 form-group-spaced">
                        <label asp-for="Location" class="master-label">Location</label>
                        <input asp-for="Location" class="master-input" />
                    </div>

                    <div class="col-md-6 form-group-spaced">
                        <label asp-for="MapLocationUrl" class="master-label">Google Maps Embed URL</label>
                        <input asp-for="MapLocationUrl" class="master-input" />
                    </div>

                    <div class="col-12 form-group-spaced mt-3">
                        <div class="form-check form-switch">
                            <input asp-for="IsActive" class="form-check-input fs-4" type="checkbox" id="flexSwitchCheckChecked" />
                            <label asp-for="IsActive" class="form-check-label fw-bold mt-1 ms-2" for="flexSwitchCheckChecked">Is Active (Visible to public)</label>
                        </div>
                    </div>
                </div>

                <hr class="my-4 border-light">

                <div class="d-flex justify-content-end gap-3">
                    <a asp-action="Index" class="btn btn-light border fw-bold px-4">Cancel</a>
                    <button type="submit" class="btn btn-primary fw-bold px-5 shadow-sm" style="background-color: #003366; border: none;">
                        <i class='bx bx-save me-1'></i> Update Scheme
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}