@model rda_raipur.Models.Brochure

@{
    Layout = "~/Views/AdminShared/_AdminLayout.cshtml";
    ViewData["Title"] = "Add New Brochure";
}

<link href="~/css/master-pages.css" rel="stylesheet" />

<div class="master-container">
    <div class="master-page-header">
        <h3 class="master-title"><i class="bi bi-file-earmark-plus text-primary"></i> Add New Brochure</h3>
        <a asp-action="Index" class="btn btn-outline-secondary fw-bold rounded-pill px-4">
            <i class="bi bi-arrow-left"></i> Back to List
        </a>
    </div>

    <div class="card master-card">
        <div class="card-body p-4">
            <form asp-action="Create" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="alert alert-danger shadow-sm border-0 mb-4"></div>

                <div class="row">
                    <div class="col-md-6 form-group-spaced">
                        <label asp-for="Title_En" class="master-label">Title (English) <span class="text-danger">*</span></label>
                        <input asp-for="Title_En" class="master-input" required placeholder="e.g. Kaushalya Mata Vihar" />
                        <span asp-validation-for="Title_En" class="text-danger small fw-bold"></span>
                    </div>

                    <div class="col-md-6 form-group-spaced">
                        <label asp-for="Title_Hi" class="master-label">Title (Hindi) <span class="text-danger">*</span></label>
                        <input asp-for="Title_Hi" class="master-input" required placeholder="उदा. कौशल्या माता विहार" />
                        <span asp-validation-for="Title_Hi" class="text-danger small fw-bold"></span>
                    </div>

                    <div class="col-md-6 form-group-spaced">
                        <label class="master-label">Upload Thumbnail Image <span class="text-danger">*</span></label>
                        <input type="file" name="imageFile" class="master-input p-1" accept="image/jpeg, image/png, image/jpg" required />
                        <small class="text-muted d-block mt-1">Recommended: JPG/PNG format.</small>
                    </div>

                    <div class="col-md-6 form-group-spaced">
                        <label class="master-label">Upload Brochure PDF <span class="text-danger">*</span></label>
                        <input type="file" name="pdfFile" class="master-input p-1" accept=".pdf" required />
                        <small class="text-muted d-block mt-1">Only PDF files allowed.</small>
                    </div>
                </div>

                <hr class="my-4 border-light">

                <div class="d-flex justify-content-end gap-3">
                    <a asp-action="Index" class="btn btn-light border fw-bold px-4">Cancel</a>
                    <button type="submit" class="btn btn-primary fw-bold px-5 shadow-sm" style="background-color: #003366; border: none;">
                        <i class="bi bi-save me-1"></i> Save Brochure
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}