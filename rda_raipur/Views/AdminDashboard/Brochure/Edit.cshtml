@model rda_raipur.Models.Brochure

@{
    Layout = "~/Views/AdminShared/_AdminLayout.cshtml";
    ViewData["Title"] = "Edit Brochure";
}

<link href="~/css/master-pages.css" rel="stylesheet" />

<div class="master-container">
    <div class="master-page-header">
        <h3 class="master-title"><i class="bi bi-pencil-square text-primary"></i> Edit Brochure</h3>
        <a asp-action="Index" class="btn btn-outline-secondary fw-bold rounded-pill px-4">
            <i class="bi bi-arrow-left"></i> Back to List
        </a>
    </div>

    <div class="card master-card">
        <div class="card-body p-4">
            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="CreatedDate" />
                <div asp-validation-summary="ModelOnly" class="alert alert-danger shadow-sm border-0 mb-4"></div>

                <div class="row">
                    <div class="col-md-6 form-group-spaced">
                        <label asp-for="Title_En" class="master-label">Title (English)</label>
                        <input asp-for="Title_En" class="master-input" required />
                        <span asp-validation-for="Title_En" class="text-danger small fw-bold"></span>
                    </div>

                    <div class="col-md-6 form-group-spaced">
                        <label asp-for="Title_Hi" class="master-label">Title (Hindi)</label>
                        <input asp-for="Title_Hi" class="master-input" required />
                        <span asp-validation-for="Title_Hi" class="text-danger small fw-bold"></span>
                    </div>

                    <div class="col-12 form-group-spaced">
                        <label class="master-label">Status</label>
                        <div class="form-check form-switch mt-2">
                            <input class="form-check-input fs-4" asp-for="IsActive" id="IsActiveSwitch">
                            <label class="form-check-label fw-bold mt-1 ms-2" for="IsActiveSwitch">Active Status</label>
                        </div>
                    </div>

                    <div class="col-md-6 form-group-spaced">
                        <label class="master-label">Update Thumbnail</label>
                        <input type="file" name="imageFile" class="master-input p-1" accept="image/*" />
                        <div class="mt-2">
                            <img src="@Model.ImagePath" class="img-thumbnail shadow-sm" style="max-height: 80px;" />
                        </div>
                    </div>

                    <div class="col-md-6 form-group-spaced">
                        <label class="master-label">Update PDF</label>
                        <input type="file" name="pdfFile" class="master-input p-1" accept=".pdf" />
                        <div class="mt-2">
                            <a href="@Model.PdfPath" target="_blank" class="btn btn-sm btn-outline-danger shadow-sm">
                                <i class="bi bi-file-pdf"></i> View Current PDF
                            </a>
                        </div>
                    </div>
                </div>

                <hr class="my-4 border-light">

                <div class="d-flex justify-content-end gap-3">
                    <a asp-action="Index" class="btn btn-light border fw-bold px-4">Cancel</a>
                    <button type="submit" class="btn btn-primary fw-bold px-5 shadow-sm" style="background-color: #003366; border: none;">
                        <i class="bi bi-save me-1"></i> Update Brochure
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}