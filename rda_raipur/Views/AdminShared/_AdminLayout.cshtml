<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] | RDA Admin Dashboard</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/admin-console.css" asp-append-version="true" />

    <script>
        if (localStorage.getItem("sidebar-collapsed") === "true") {
            document.documentElement.classList.add('sidebar-is-collapsed');
            // Body पर भी क्लास लगा दें ताकि CSS मार्जिन तुरंत अप्लाई हो
            document.body.classList.add('sidebar-is-collapsed');
        }
    </script>

    <style>
        body {
            background-color: #fffbf5;
            font-family: 'Segoe UI', Tahoma, sans-serif;
            margin: 0;
            padding: 0;
            overflow-x: hidden;
        }

        /* 1. डिफॉल्ट चौड़ाई (Sidebar Open) */
        .main-content {
            padding: 10px 15px;
            margin-left: 285px;
            transition: margin-left 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            min-height: calc(100vh - 70px);
        }

        /* 2. साइडबार बंद होने पर मार्जिन (CSS Class Control) */
        body.sidebar-is-collapsed .main-content {
            margin-left: 75px !important;
        }

        /* 📱 MOBILE */
        @@media (max-width: 991.98px) {
            .main-content {
                margin-left: 0 !important;
                padding: 10px;
            }
        }
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <partial name="~/Views/AdminShared/_Header.cshtml" />
    <partial name="~/Views/AdminShared/_Sidebar.cshtml" />

    <main class="main-content">
        <div class="content-container">
            @RenderBody()
        </div>
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>