@using Microsoft.AspNetCore.Localization
@using rda_raipur.Data
@using System.Security.Claims
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext _context

@{
    var requestCultureFeature = Context.Features.Get<IRequestCultureFeature>();
    var currentCulture = requestCultureFeature?.RequestCulture.UICulture.Name ?? "hi";
    bool isEnglish = currentCulture.StartsWith("en");

    // ✨ नाम फेच करने की लॉजिक ✨
    string displayName = User.Identity.Name;
    var userIdStr = User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

    if (int.TryParse(userIdStr, out int userId))
    {
        var emp = await _context.EmployeeDetails.FirstOrDefaultAsync(e => e.UserId == userId);
        if (emp != null)
        {
            displayName = $"{emp.Fname} {emp.Lname}";
        }
    }
}

<style>
    .admin-header {
        background-color: #ffffff;
        height: 70px;
        box-shadow: 0 4px 20px -2px rgba(60, 50, 40, 0.05);
        display: flex;
        align-items: center;
        padding: 0 24px;
        position: sticky;
        top: 0;
        z-index: 1060;
        border-bottom: 2px solid #f97316; /* हेडर के नीचे ऑरेंज लाइन */
    }

    .mobile-hamburger-btn {
        background: #fffbf5;
        border: 1px solid #e7dccf;
        border-radius: 8px;
        color: #272522;
        font-size: 1.5rem;
        padding: 6px 12px;
        margin-right: 15px;
        cursor: pointer;
        display: none;
        align-items: center;
        justify-content: center;
        transition: 0.3s ease;
    }

        .mobile-hamburger-btn:hover {
            background: #f0e4d8;
        }

    .header-brand {
        display: flex;
        align-items: center;
        gap: 14px;
    }

        .header-brand img {
            height: clamp(40px, 4.5vw, 50px);
            object-fit: contain;
        }

    .brand-text-en {
        color: #1e293b;
        font-size: clamp(0.85rem, 1.1vw + 0.1rem, 1.1rem);
        line-height: 1.1;
        font-weight: 700;
        letter-spacing: 0.8px;
        text-transform: uppercase;
    }

    .brand-text-hi {
        color: #ea580c;
        font-size: clamp(0.75rem, 0.95vw + 0.1rem, 0.95rem);
        font-weight: 700;
        margin-top: 2px;
    }

    .header-tools {
        gap: 20px;
    }

    .lang-switcher-pill {
        display: flex;
        background: #f5ede4;
        border-radius: 30px;
        padding: 4px;
        border: 1px solid #e7dccf;
    }

        .lang-switcher-pill a {
            font-size: 0.8rem;
            font-weight: 700;
            padding: 6px 14px;
            border-radius: 20px;
            text-decoration: none;
            color: #78716c;
            transition: all 0.3s ease;
        }

            .lang-switcher-pill a.active {
                background: #ffffff;
                color: #ea580c;
                box-shadow: 0 2px 6px rgba(120,100,80,0.1);
            }

            .lang-switcher-pill a:hover:not(.active) {
                color: #292524;
            }

    .page-title-display {
        font-size: 1rem;
        font-weight: 700;
        color: #44403c;
        border-left: 2px solid #e7dccf;
        padding-left: 20px;
        margin: 0;
    }

    .user-profile-btn {
        background: #ffffff;
        border: 1px solid #e7dccf;
        border-radius: 50px;
        padding: 6px 16px 6px 6px;
        transition: 0.3s ease;
    }

        .user-profile-btn:hover {
            background: #fffbf5;
            border-color: #d6c5b3;
            box-shadow: 0 2px 8px rgba(120,100,80,0.08);
        }

    .avatar-circle {
        width: 36px;
        height: 36px;
        background: linear-gradient(135deg, #272522, #44403c);
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
    }

    @@media (max-width: 991.98px) {
        .mobile-hamburger-btn {
            display: flex;
        }

        .admin-header {
            height: 65px;
            padding: 0 15px;
        }

        .brand-text-en, .brand-text-hi {
            font-size: 0.8rem;
        }

        .page-title-display {
            display: none;
        }
    }
</style>

<header class="admin-header justify-content-between">
    <div class="d-flex align-items-center overflow-hidden">
        <button class="mobile-hamburger-btn shadow-sm" id="mobileMenuTrigger">
            <i class="bi bi-list"></i>
        </button>

        <a href="@Url.Action("Index", "AdminDashboard")" class="header-brand text-decoration-none">
            <img src="~/images/rda-logo.png" alt="RDA Logo" />
            <div class="d-flex flex-column justify-content-center">
                <span class="brand-text-en">RAIPUR DEVELOPMENT AUTHORITY</span>
                <span class="brand-text-hi">रायपुर विकास प्राधिकरण</span>
            </div>
        </a>
    </div>

    <div class="header-tools d-flex align-items-center">

        <h6 class="page-title-display d-none d-xl-block">
            @ViewData["Title"]
        </h6>

        <div class="dropdown">
            <a href="#" class="d-flex align-items-center text-decoration-none dropdown-toggle user-profile-btn" id="profileDropdown" data-bs-toggle="dropdown">
                <div class="avatar-circle me-2 shadow-sm"><i class="bi bi-person-fill"></i></div>
                <div class="d-none d-sm-block text-start lh-1">
                    <div class="text-dark fw-bold" style="font-size: 0.85rem;">@displayName</div>
                    <small class="text-muted fw-semibold" style="font-size: 0.7rem;">@(User.IsInRole("Admin") ? (isEnglish ? "Administrator" : "एडमिनिस्ट्रेटर") : (isEnglish ? "Staff Member" : "स्टाफ सदस्य"))</small>
                </div>
            </a>
            <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-3 p-2" style="border-radius: 12px; min-width: 220px; animation: fadeIn 0.2s ease;">
                <li class="px-3 py-2 rounded-3 mb-2 text-center" style="background-color: #fffbf5;">
                    <div class="avatar-circle mx-auto mb-2" style="width: 45px; height: 45px; font-size: 1.5rem;"><i class="bi bi-person-fill"></i></div>
                    <span class="d-block fw-bold text-dark">@displayName</span>
                    <span class="d-block small text-muted">@(User.IsInRole("Admin") ? "Admin Account" : "Staff Account")</span>
                </li>
                
                
                <li><hr class="dropdown-divider"></li>
                <li>
                    <a class="dropdown-item rounded-2 py-2 text-danger fw-bold" href="@Url.Action("Logout", "Account")">
                        <i class="bi bi-box-arrow-right me-2"></i> @(isEnglish ? "Sign Out" : "साइन आउट")
                    </a>
                </li>
            </ul>
        </div>
    </div>
</header>